---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const included = [
  'Unlimited users',
  'Unlimited projects',
  'Bids & estimates',
  'Pay applications',
  'Change orders',
  'Site logs & daily reports',
  'Gantt charts & scheduling',
  'Sales pipeline & CRM',
  'Time tracking',
  'Role-based permissions',
  'Reports & analytics',
  'Document management',
];

const faqs = [
  {
    question: 'What is the best software for electrical contractors?',
    answer:
      'For project-based electrical subcontractors — commercial TI, multifamily, new construction — BuildWorkPro covers estimating, phase scheduling, AIA-style pay applications, change orders, and crew time tracking in one $79/month plan. If you run residential service calls and dispatch trucks all day, you want a field-service tool instead. BuildWorkPro is built for contract work that gets bid, phased, and billed monthly.',
  },
  {
    question: 'Can I estimate from a catalog of parts and labor?',
    answer:
      'Yes. BuildWorkPro has a product catalog with SKUs, costs, and sell prices for the items you price repeatedly — breakers, devices, wire by the foot, bend-and-pull labor. You can import vendor price lists from CSV, so when your supplier reprices wire or gear you update the catalog once instead of editing every estimate. Bid line items pull straight from the catalog with material and labor broken out per line.',
  },
  {
    question: 'How does progress billing work for electrical work?',
    answer:
      'BuildWorkPro generates AIA-style pay applications from a schedule of values. Break the SOV into the lines your GC expects — underground, rough-in, wire and terminate, gear, trim, low voltage — then bill percent complete on each line every month. Retainage is tracked automatically, and every pay app carries an approval status so you know what has been submitted, approved, or paid.',
  },
  {
    question: 'Can my journeymen log time and site reports from the field?',
    answer:
      'Yes. Journeymen log hours against specific projects and tasks, and file daily site logs with personnel on site, work performed, materials received, issues, and photos. The restricted field-crew role gives them exactly that — time entries and site logs — without exposing your bids, pricing, or pay applications.',
  },
  {
    question: 'How much does BuildWorkPro cost for an electrical contractor?',
    answer:
      '$79/month flat, or $790/year — every feature, unlimited users, unlimited projects. There are no per-user fees, so putting every journeyman and apprentice on the system costs the same as putting one. The 14-day free trial does not require a credit card.',
  },
];
---

<Layout
  title="Electrical Contractor Software with Estimating | BuildWorkPro"
  description="Estimating, project phases, pay apps, and crew time tracking for electrical subcontractors. $79/month flat, unlimited users. Start a 14-day free trial."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">
          For Electrical Contractors
        </p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Electrical Contractor Software
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Electrical estimating from a catalog of parts and labor, phase scheduling from underground
          to trim-out, AIA-style pay apps, and crew time from the field — one system, $79/month
          flat. BuildWorkPro is built for the way electrical subs actually work.
        </p>
        <div class="mt-8">
          <a
            href={config.signupUrl}
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
            >Start free trial</a
          >
          <p class="mt-3 text-sm text-slate-400">14-day free trial. No credit card required.</p>
        </div>
      </div>
    </section>

    <!-- Why electrical contractors use BuildWorkPro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">
        Why electrical contractors use BuildWorkPro
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Track every phase of the job</h3>
          <p class="text-sm text-slate-500">
            Break projects into phases — underground, rough-in, trim, devices, final connections —
            with tasks, dependencies, and a Gantt view in
            <a href="/features/project-management/" class="text-brand-600 hover:underline"
              >project management</a
            >. Know exactly where each job stands without calling the foreman.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Estimate from your own numbers
          </h3>
          <p class="text-sm text-slate-500">
            Price panel schedules and fixture counts as
            <a href="/features/construction-bidding/" class="text-brand-600 hover:underline"
              >bid line items</a
            >
            pulled from your product catalog, with material and labor broken out per line. Import conduit
            and wire pricing from vendor CSV price lists, and duplicate past bids for similar scope.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Pay apps without the headache</h3>
          <p class="text-sm text-slate-500">
            Generate AIA-style
            <a href="/features/pay-applications/" class="text-brand-600 hover:underline"
              >pay applications</a
            >
            tied to your schedule of values. Bill percent complete and track retainage on each line —
            feeders, branch circuits, gear — with approval status visible from submitted to paid.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Know where crew hours go</h3>
          <p class="text-sm text-slate-500">
            Journeymen and apprentices log hours against specific projects and tasks with
            <a href="/features/time-tracking/" class="text-brand-600 hover:underline"
              >time tracking</a
            >. Review entries before payroll and see which jobs are eating labor.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Handle change orders fast</h3>
          <p class="text-sm text-slate-500">
            When the GC adds circuits, moves panels, or requests a service upgrade, write a priced
            <a href="/features/change-orders/" class="text-brand-600 hover:underline"
              >change order</a
            >
            with its own line items. Track approval status, and the approved amount rolls into your contract
            sum.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Daily logs from every site</h3>
          <p class="text-sm text-slate-500">
            Crews file site logs with personnel on site, work performed, materials received, and
            photos. Record inspector visits and log anything they flag as an issue — tagged, so you
            can find it again at closeout.
          </p>
        </div>
      </div>
    </section>

    <!-- Product proof -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 space-y-10">
      <Screenshot
        src="/screenshots/solutions/electrical/bid-detail-overview.png"
        alt="BuildWorkPro bid detail page showing an electrical estimate with line items, material and labor cost breakdowns, and bid totals"
        caption="An electrical estimate in BuildWorkPro: line items with material and labor broken out — price a panel swap or a full TI fit-out from the same catalog."
      />
      <Screenshot
        src="/screenshots/solutions/electrical/project-phases-tasks.png"
        alt="BuildWorkPro project page showing phases and tasks with schedule dates and progress"
        caption="Phases and tasks on a project: sequence underground, rough-in, inspection, and trim with dependencies, and watch the Gantt update."
      />
    </section>

    <!-- What's included -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-8">
        Everything you need at one flat price
      </h2>
      <p class="text-center text-slate-500 mb-8">
        $79/month for unlimited users and projects. No per-user fees.
      </p>
      <div class="grid sm:grid-cols-2 gap-3">
        {
          included.map((item) => (
            <div class="flex items-center gap-2.5">
              <svg
                class="w-4 h-4 text-brand-600 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-slate-600">{item}</span>
            </div>
          ))
        }
      </div>
    </section>

    <FAQSection faqs={faqs} />

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        Run your electrical jobs on one flat price
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        $79/month covers estimating, pay apps, change orders, scheduling, site logs, and time
        tracking — unlimited users, every feature. 14-day free trial, no credit card required.
      </p>
      <a
        href={config.signupUrl}
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
        >Start free trial</a
      >
      <p class="mt-6 text-sm text-slate-400">
        Comparing platforms? See how BuildWorkPro stacks up against
        <a href="/compare/procore-alternative/" class="text-brand-600 hover:underline">Procore</a>
        and
        <a href="/compare/buildertrend-alternative/" class="text-brand-600 hover:underline"
          >Buildertrend</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
