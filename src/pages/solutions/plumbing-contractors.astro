---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Project Management Software for Plumbing Contractors | BuildWorkPro" description="Construction software for plumbing subcontractors. Track bids, manage projects, handle pay apps and change orders. $79/month, unlimited users.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">For Plumbing Contractors</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Project Management for Plumbing Contractors
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Manage rough-in through fixture trim across every job from one platform. Track bids on new construction and tenant improvements, schedule your crews for underground and top-out work, and submit pay apps that match your schedule of values. BuildWorkPro keeps your plumbing operation organized.
        </p>
        <div class="mt-8">
          <!-- TODO: Restore "Start free trial" button at launch -->
          <button data-request-access class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg">Request Access</button>
          <p class="mt-3 text-sm text-slate-400">Pre-launch access available for select contractors.</p>
        </div>
      </div>
    </section>

    <!-- Why plumbing contractors use BuildWorkPro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">Why plumbing contractors use BuildWorkPro</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384-3.065A2.162 2.162 0 005 13.94V18a2.25 2.25 0 002.25 2.25h9.5A2.25 2.25 0 0019 18v-4.06c0-.766-.404-1.475-1.036-1.835L12.58 15.17a2.162 2.162 0 01-1.16 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M18.375 2.25c-1.035 0-1.875.84-1.875 1.875v3.024a.75.75 0 01-.375.65l-2.251 1.283a2.162 2.162 0 01-1.16 0L10.5 7.799a.75.75 0 01-.375-.65V4.125c0-1.036-.84-1.875-1.875-1.875h-3.5A2.25 2.25 0 002.5 4.375V6a2.25 2.25 0 002.25 2.25h14.5A2.25 2.25 0 0021.5 6V4.375a2.25 2.25 0 00-2.25-2.125h-.875z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Manage every phase of the job</h3>
          <p class="text-sm text-slate-500">Track work from underground and slab rough-in through top-out, fixture trim, and final testing. See exactly where each project stands across all your active jobs.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Win bids with accurate estimates</h3>
          <p class="text-sm text-slate-500">Build bids using your standard rates for copper, PEX, cast iron, and DWV assemblies. Clone previous bids for similar building types and get proposals out faster.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Track inspections and testing</h3>
          <p class="text-sm text-slate-500">Log pressure tests, backflow certifications, and inspection results right in the project. Never miss a required test or show up to a site unprepared for the inspector.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Pay apps tied to your SOV</h3>
          <p class="text-sm text-slate-500">Generate pay applications that match your schedule of values line by line. Track retainage, stored materials, and percent complete for rough-in, top-out, and trim phases.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Coordinate crews and service calls</h3>
          <p class="text-sm text-slate-500">Assign plumbers to new construction and service work. Balance your crew between multi-family rough-ins and commercial TI projects without conflicts or gaps.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Change orders under control</h3>
          <p class="text-sm text-slate-500">When the architect adds fixtures or reroutes waste lines, document the change order with scope, cost, and approval status. Keep your contract value accurate throughout the job.</p>
        </div>
      </div>
    </section>

    <!-- What's included -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-8">Everything you need at one flat price</h2>
      <p class="text-center text-slate-500 mb-8">$79/month for unlimited users and projects. No per-user fees.</p>
      <div class="grid sm:grid-cols-2 gap-3">
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Unlimited users</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Unlimited projects</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Bids & estimates</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Pay applications</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Change orders</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Site logs & daily reports</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Gantt charts & scheduling</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Sales pipeline & CRM</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Time tracking</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Role-based permissions</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Reports & analytics</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Document management</span>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Ready to streamline your plumbing business?</h2>
      <p class="text-lg text-slate-500 mb-8">Join other plumbing contractors who've ditched spreadsheets for BuildWorkPro.</p>
      <!-- TODO: Restore "Start free trial" button at launch -->
      <button data-request-access class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg">Request Access</button>
    </section>
  </main>
  <Footer />
</Layout>
