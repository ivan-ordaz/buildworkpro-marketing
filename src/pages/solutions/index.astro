---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

const solutions = [
  {
    title: 'HVAC Contractors',
    description:
      'From ductwork rough-in to equipment startup. Bid commercial and residential mechanical jobs, coordinate sheet metal crews, and submit pay apps without the month-end scramble.',
    href: '/solutions/hvac-contractors/',
    color: 'rose',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  },
  {
    title: 'Electrical Contractors',
    description:
      'Track service jobs, panel upgrades, and large commercial wire pulls. Submit AIA-style pay apps for prevailing wage work and keep your foremen logging hours from the field.',
    href: '/solutions/electrical-contractors/',
    color: 'amber',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Plumbing Contractors',
    description:
      'Manage rough-in through trim across new construction and remodels. Bid jobs with itemized fixture counts, track change orders for scope creep, and bill progress monthly.',
    href: '/solutions/plumbing-contractors/',
    color: 'cyan',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    title: 'Concrete Contractors',
    description:
      'Bid by the cubic yard or square foot, plan pour sequences as phases on a Gantt, and document deliveries and inspections in daily logs. Flatwork, foundations, and structural pours in one place.',
    href: '/solutions/concrete-contractors/',
    color: 'slate',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  },
  {
    title: 'Roofing Contractors',
    description:
      'Tear-offs, re-roofs, and commercial flat roofs. Bid by the square, put rain delays on the record with dated site logs, and bill completed phases with AIA-style pay apps.',
    href: '/solutions/roofing-contractors/',
    color: 'indigo',
    icon: 'M3 12l9-9 9 9M5 10v10a1 1 0 001 1h12a1 1 0 001-1V10',
  },
  {
    title: 'Framing Contractors',
    description:
      'Track stick-built and prefab framing across multi-family and custom homes. Bid by board foot or square foot, manage carpenter crews, and stay ahead of inspections.',
    href: '/solutions/framing-contractors/',
    color: 'emerald',
    icon: 'M4 6h16M4 10h16M4 14h16M4 18h16',
  },
];

const colorMap: Record<string, { bg: string; icon: string; ring: string }> = {
  rose: { bg: 'bg-rose-50', icon: 'text-rose-600', ring: 'ring-rose-100' },
  amber: { bg: 'bg-amber-50', icon: 'text-amber-600', ring: 'ring-amber-100' },
  cyan: { bg: 'bg-cyan-50', icon: 'text-cyan-600', ring: 'ring-cyan-100' },
  slate: { bg: 'bg-slate-100', icon: 'text-slate-700', ring: 'ring-slate-200' },
  indigo: { bg: 'bg-indigo-50', icon: 'text-indigo-600', ring: 'ring-indigo-100' },
  emerald: { bg: 'bg-emerald-50', icon: 'text-emerald-600', ring: 'ring-emerald-100' },
};
---

<Layout
  title="Construction Software by Trade – Solutions | BuildWorkPro"
  description="Specialty trade construction software for HVAC, electrical, plumbing, concrete, roofing, and framing contractors. Bidding, pay apps, project management — all in one platform."
>
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Solutions</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Construction software, tuned to your trade
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          BuildWorkPro is built for specialty subcontractors. Pick your trade to see how it handles
          the workflows your crews actually run every day.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          solutions.map((solution) => {
            const colors = colorMap[solution.color];
            return (
              <a
                href={solution.href}
                class="group p-8 rounded-2xl border border-slate-100 hover:border-slate-200 bg-white hover:shadow-lg transition-all duration-300"
              >
                <div class={`inline-flex p-3 rounded-xl ${colors.bg} ring-1 ${colors.ring} mb-5`}>
                  <svg
                    class={`w-6 h-6 ${colors.icon}`}
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d={solution.icon} />
                  </svg>
                </div>
                <h2 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-brand-600 transition-colors">
                  {solution.title}
                </h2>
                <p class="text-slate-500 leading-relaxed mb-4">{solution.description}</p>
                <span class="inline-flex items-center text-sm font-medium text-brand-600 group-hover:gap-2 gap-1.5 transition-all">
                  Learn more
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
            );
          })
        }
      </div>
    </div>

    <div class="mt-20">
      <CTA />
    </div>
  </main>
  <Footer />
</Layout>
