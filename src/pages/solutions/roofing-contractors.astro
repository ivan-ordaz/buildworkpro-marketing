---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const included = [
  'Unlimited users',
  'Unlimited projects',
  'Bids & estimates',
  'Pay applications',
  'Change orders',
  'Site logs & daily reports',
  'Gantt charts & scheduling',
  'Sales pipeline & CRM',
  'Time tracking',
  'Role-based permissions',
  'Reports & analytics',
  'Document management',
];

const faqs = [
  {
    question: 'What is the best software for roofing contractors?',
    answer:
      'For commercial and new-construction roofing subs — and reroof contractors working for GCs and building owners — BuildWorkPro covers the full job: line-item bids, AIA-style pay applications, change orders, and dated site logs at $79/month flat. It is not an insurance-restoration or door-to-door sales tool; if your business runs on canvassing and claims, a restoration CRM is a better fit. BuildWorkPro is built for contract work that gets bid, scheduled, and progress-billed.',
  },
  {
    question: 'How do I document rain delays and protect against backcharges?',
    answer:
      'Write a site log the day it happens: tag the entry Delay, note who was on site and what work stopped, and attach photos of the deck and staged materials. Every log is dated, so when a GC questions the schedule — or floats a backcharge — months later, you have a contemporaneous record instead of memory. Foremen can file logs from the field using the restricted field-crew role.',
  },
  {
    question: 'Can I price tear-off and disposal into the bid?',
    answer:
      "Yes. Tear-off goes in as its own line item with labor and material cost items, and job-wide costs like dumpsters, disposal fees, and permits go in as bid-level project costs that BuildWorkPro spreads across your line items' sell prices. Nothing rides for free, and the GC sees a clean PDF proposal instead of your cost breakdown.",
  },
  {
    question: 'How does progress billing work on big roofs?',
    answer:
      'You build a schedule of values broken out by roof area or phase — tear-off, dry-in, flashing, finish — then submit a pay application each period billing the percent complete on every line. Retainage is calculated automatically, and each pay app moves through approval statuses so you always know what has been submitted, approved, and paid.',
  },
  {
    question: 'How much does roofing contractor software cost?',
    answer:
      'BuildWorkPro is $79/month flat, or $790/year — one price, unlimited users, every feature. There are no per-user fees, so adding estimators, project managers, and foremen costs nothing extra. Every account starts with a 14-day free trial, no credit card required.',
  },
];
---

<Layout
  title="Roofing Contractor Software for Commercial Subs | BuildWorkPro"
  description="Roofing contractor software for commercial subs: bids by the square, AIA-style pay apps, change orders, crew scheduling. $79/month flat, 14-day free trial."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">
          For Roofing Contractors
        </p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Roofing Contractor Software
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          From tear-off to final inspection, run every roofing job in one place. Bid reroofs and new
          construction by the square, schedule crews on a Gantt chart, put rain delays on the record
          with dated site logs, and bill big roofs with AIA-style pay applications — for $79/month
          flat.
        </p>
        <div class="mt-8">
          <a
            href={config.signupUrl}
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
            >Start free trial</a
          >
          <p class="mt-3 text-sm text-slate-400">14-day free trial. No credit card required.</p>
        </div>
      </div>
    </section>

    <!-- Why roofing contractors use BuildWorkPro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">
        Why roofing contractors use BuildWorkPro
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Plan tear-off, dry-in, and install as phases
          </h3>
          <p class="text-sm text-slate-500">
            Break each roof into phases with tasks and dependencies, then run the job from a Gantt
            chart. When rain pushes tear-off back two days, drag the task and everything downstream
            moves with it. See
            <a href="/features/project-management/" class="text-brand-600 hover:underline"
              >project management</a
            >.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Bid by the square, with waste in the numbers
          </h3>
          <p class="text-sm text-slate-500">
            Estimate tear-off, decking repair, underlayment, flashing, and finish roofing as line
            items with material and labor costs — squares plus your waste factor, priced from your
            own product catalog. TPO, EPDM, shingle, or metal. See
            <a href="/features/construction-bidding/" class="text-brand-600 hover:underline"
              >bidding & estimating</a
            >.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Put rain delays on the record</h3>
          <p class="text-sm text-slate-500">
            When weather shuts the roof down, write a dated
            <a href="/features/site-logs/" class="text-brand-600 hover:underline">site log</a>, tag
            it Delay, and attach photos of the deck. Months later, when the GC asks why the schedule
            slipped — or floats a backcharge — you have it in writing.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Bill big roofs by area or phase
          </h3>
          <p class="text-sm text-slate-500">
            Build a schedule of values by roof section — tear-off, dry-in, flashing, finish — and
            submit AIA-style
            <a href="/features/pay-applications/" class="text-brand-600 hover:underline"
              >pay applications</a
            >
            for the percent complete each period, with retainage tracked on every line.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Price storm and extra work as change orders
          </h3>
          <p class="text-sm text-slate-500">
            Rotten decking under tear-off, hail damage, added scope — write it up as a
            <a href="/features/change-orders/" class="text-brand-600 hover:underline"
              >change order</a
            >
            with priced line items and back it with site log photos. Once approved, it rolls into the
            contract sum so your next pay app bills against the right number.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Crews see their jobs, not your numbers
          </h3>
          <p class="text-sm text-slate-500">
            The restricted field-crew role lets foremen file site logs and log hours against
            projects and tasks — without seeing bids, margins, or billing. Hours land in time
            tracking with a review status, ready to check before payroll.
          </p>
        </div>
      </div>
    </section>

    <!-- Product screenshots -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 space-y-10">
      <Screenshot
        src="/screenshots/02-pipeline-kanban.png"
        alt="BuildWorkPro sales pipeline kanban board tracking roofing leads by stage"
        caption="Every roof you're chasing on one pipeline board — from first call with the GC to signed contract, then converted to a bid."
      />
      <Screenshot
        src="/screenshots/09-change-order-detail.png"
        alt="BuildWorkPro change order detail with priced line items and approval status"
        caption="A priced change order for decking found rotten at tear-off — once approved, it rolls straight into the contract sum."
      />
    </section>

    <!-- What's included -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-8">
        Everything you need at one flat price
      </h2>
      <p class="text-center text-slate-500 mb-8">
        $79/month for unlimited users and projects. No per-user fees.
      </p>
      <div class="grid sm:grid-cols-2 gap-3">
        {
          included.map((item) => (
            <div class="flex items-center gap-2.5">
              <svg
                class="w-4 h-4 text-brand-600 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-slate-600">{item}</span>
            </div>
          ))
        }
      </div>
    </section>

    <FAQSection faqs={faqs} />

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        Bid it, schedule it, bill it — one system
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        $79/month flat covers your whole company — unlimited users, every feature, no per-user fees.
        Try everything free for 14 days, no credit card required.
      </p>
      <a
        href={config.signupUrl}
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
        >Start free trial</a
      >
      <p class="mt-8 text-sm text-slate-400">
        Comparing tools? See how BuildWorkPro stacks up as a
        <a href="/compare/procore-alternative/" class="text-brand-600 hover:underline"
          >Procore alternative</a
        >
        or a
        <a href="/compare/buildertrend-alternative/" class="text-brand-600 hover:underline"
          >Buildertrend alternative</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
