---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const included = [
  'Unlimited users',
  'Unlimited projects',
  'Bids & estimates',
  'Pay applications',
  'Change orders',
  'Site logs & daily reports',
  'Gantt charts & scheduling',
  'Sales pipeline & CRM',
  'Time tracking',
  'Role-based permissions',
  'Reports & analytics',
  'Document management',
];

const faqs = [
  {
    question: 'What is the best software for HVAC contractors?',
    answer:
      'It depends on the work you do. Commercial and mechanical subcontractors doing project-based contract work — bid the job, install, bill against a schedule of values — need bidding, scheduling, pay applications, and change orders, which is what BuildWorkPro is built for. Residential service businesses running dispatch and maintenance calls need a service-call tool instead; BuildWorkPro is not a dispatch platform.',
  },
  {
    question: 'Can I bill for equipment, ductwork, and startup as separate line items?',
    answer:
      'Yes. Pay applications in BuildWorkPro are built on a schedule of values, so equipment setting, duct rough-in, piping, insulation, controls, and startup each get their own line with a scheduled value and percent complete. Retainage is tracked on the pay app, and totals roll up AIA-style so the GC sees billing that matches the contract breakdown.',
  },
  {
    question: 'How do HVAC crews use it in the field?',
    answer:
      'Crews fill out daily site logs — personnel on site, work performed, materials received, visitors, and issues, with photos attached. They log hours against projects and tasks in quarter-hour increments, and entries go through a review status before they count. The restricted field-crew role gives them projects, site logs, time tracking, and documents without exposing bids, pay apps, or pricing.',
  },
  {
    question: 'Does it handle change orders when the owner adds zones or upgrades equipment?',
    answer:
      'Yes. Create a change order with priced line items for the added zones or the equipment swap, send it through the approval flow, and track its status. Once approved, the change order rolls into the contract sum, so your next pay application bills against the updated contract value instead of the original number.',
  },
  {
    question: 'How much does it cost?',
    answer:
      'BuildWorkPro is $79/month flat (or $790/year) for unlimited users and every feature — bidding, scheduling, pay applications, change orders, site logs, time tracking, and CRM. There are no per-user fees, and the 14-day free trial requires no credit card.',
  },
];
---

<Layout
  title="HVAC Contractor Software for Mechanical Subs | BuildWorkPro"
  description="HVAC contractor software for mechanical subs: line-item bids, Gantt scheduling, AIA-style pay apps, and change orders. $79/month flat, 14-day free trial."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">
          For HVAC Contractors
        </p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          HVAC Contractor Software
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          From ductwork rough-in to equipment startup and balancing, manage the whole mechanical job
          in one place. Track bids across commercial and residential projects, coordinate sheet
          metal crews and pipe fitters, and submit pay apps without the end-of-month scramble.
        </p>
        <div class="mt-8">
          <a
            href={config.signupUrl}
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
            >Start free trial</a
          >
          <p class="mt-3 text-sm text-slate-400">14-day free trial. No credit card required.</p>
        </div>
      </div>
    </section>

    <!-- Why HVAC contractors use BuildWorkPro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">
        Why HVAC contractors use BuildWorkPro
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Coordinate equipment and ductwork
          </h3>
          <p class="text-sm text-slate-500">
            Schedule duct rough-in around other trades, sequence equipment setting after curb and
            delivery dates, and plan startup at the end — as phases and tasks with dependencies on a
            Gantt chart. See
            <a href="/features/project-management/" class="text-brand-600 hover:underline"
              >project management</a
            >.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Build mechanical bids faster</h3>
          <p class="text-sm text-slate-500">
            Assemble bids with line items for ductwork fabrication, piping, insulation, controls,
            and equipment — each broken into material and labor costs. Duplicate a past job with
            similar tonnage and scope instead of starting from a blank sheet. See
            <a href="/features/construction-bidding/" class="text-brand-600 hover:underline"
              >bidding & estimating</a
            >.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Startup and commissioning records
          </h3>
          <p class="text-sm text-slate-500">
            Record startup and balancing work in daily
            <a href="/features/site-logs/" class="text-brand-600 hover:underline">site logs</a> — what
            was tested, who was on site, photos of nameplates and readings. Attach balancing reports to
            the project's documents so sign-off lives with the job.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Pay apps matched to progress</h3>
          <p class="text-sm text-slate-500">
            Generate
            <a href="/features/pay-applications/" class="text-brand-600 hover:underline"
              >pay applications</a
            > against your schedule of values. Bill duct rough-in, equipment setting, piping, insulation,
            controls, and startup as separate line items with accurate percent complete — retainage tracked,
            AIA-style.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Track sheet metal and pipe crew hours
          </h3>
          <p class="text-sm text-slate-500">
            Sheet metal installers, pipe fitters, and controls techs log hours per project and task
            in quarter-hour increments, with a review status before hours count. See
            <a href="/features/time-tracking/" class="text-brand-600 hover:underline"
              >time tracking</a
            >. A restricted field-crew role keeps pricing and pay apps out of view.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Change orders documented instantly
          </h3>
          <p class="text-sm text-slate-500">
            When the owner adds zones, upgrades equipment, or reroutes duct, write a
            <a href="/features/change-orders/" class="text-brand-600 hover:underline"
              >change order</a
            > with priced line items, send it for approval, and let the approved amount roll into the
            contract sum — so your next pay app bills the updated number.
          </p>
        </div>
      </div>
    </section>

    <!-- Product proof -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="space-y-12">
        <Screenshot
          src="/screenshots/17-project-gantt.png"
          alt="BuildWorkPro Gantt chart showing project phases and tasks with dependencies"
          caption="Duct rough-in, equipment setting, and startup sequenced on the Gantt — task dependencies show what slips when a delivery date moves."
        />
        <Screenshot
          src="/screenshots/13-pay-app-detail.png"
          alt="BuildWorkPro pay application detail showing the schedule of values with line items and retainage"
          caption="An AIA-style pay app: equipment, ductwork, piping, and startup billed as separate schedule-of-values lines, with percent complete and retainage tracked."
        />
      </div>
    </section>

    <!-- What's included -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-8">
        Everything you need at one flat price
      </h2>
      <p class="text-center text-slate-500 mb-8">
        $79/month for unlimited users and projects. No per-user fees.
      </p>
      <div class="grid sm:grid-cols-2 gap-3">
        {
          included.map((item) => (
            <div class="flex items-center gap-2.5">
              <svg
                class="w-4 h-4 text-brand-600 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-slate-600">{item}</span>
            </div>
          ))
        }
      </div>
    </section>

    <FAQSection faqs={faqs} />

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        Run your next mechanical job in BuildWorkPro
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        One flat price — $79/month for unlimited users and every feature. The 14-day trial is long
        enough to run a real job through it, and it doesn't ask for a credit card.
      </p>
      <a
        href={config.signupUrl}
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
        >Start free trial</a
      >
      <p class="mt-6 text-sm text-slate-400">
        Comparing platforms? See how BuildWorkPro stacks up against
        <a href="/compare/procore-alternative/" class="text-brand-600 hover:underline">Procore</a>
        and
        <a href="/compare/buildertrend-alternative/" class="text-brand-600 hover:underline"
          >Buildertrend</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
