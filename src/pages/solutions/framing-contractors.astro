---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const included = [
  'Unlimited users',
  'Unlimited projects',
  'Bids & estimates',
  'Pay applications',
  'Change orders',
  'Site logs & daily reports',
  'Gantt charts & scheduling',
  'Sales pipeline & CRM',
  'Time tracking',
  'Role-based permissions',
  'Reports & analytics',
  'Document management',
];

const faqs = [
  {
    question: 'What is the best software for framing contractors?',
    answer:
      'The best framing contractor software handles what framing subs actually deal with: lumber-heavy estimates, crews spread across buildings, and progress billing tied to percent complete. BuildWorkPro is built for trade subcontractors — framing subs use it on residential tracts, multifamily projects, and commercial wood and metal stud jobs. Bidding, scheduling, site logs, time tracking, and AIA-style pay applications are all in one system at one flat price.',
  },
  {
    question: 'How do I keep up with lumber price swings when bidding?',
    answer:
      "Keep lumber pricing in your product catalog and re-import your supplier's CSV price list whenever a new quote lands — the column mapping is saved, so refreshing prices takes minutes, not an afternoon. For repeat work, duplicate a past bid and update the costs instead of rebuilding the estimate. Margin, overhead, and commission are set on the Rates tab, so when material costs move, your sell price moves with them.",
  },
  {
    question: 'Can I bill per building or per unit?',
    answer:
      "Yes. Pay applications in BuildWorkPro run on a schedule of values you structure however you bill — a line per building, per unit, or per phase like walls, floor systems, and roof framing. Percent complete and retainage are tracked per line, so Building 3's framing bills separately from Building 4's.",
  },
  {
    question: 'How do I track crews across multiple jobsites?',
    answer:
      "Crew members log hours against a specific project and task, so you can see who worked which jobsite and what each building's framing actually cost in labor. Project schedules with tasks and Gantt charts show where each crew should be next as buildings dry in. The restricted field-crew role gives workers site logs and time tracking without exposing bids, contracts, or pricing.",
  },
  {
    question: 'How much does framing contractor software cost?',
    answer:
      "BuildWorkPro is $79/month flat, or $790/year, with unlimited users and unlimited projects — every module included. There are no per-user fees, so putting your whole crew on it costs nothing extra. The 14-day free trial doesn't require a credit card.",
  },
];
---

<Layout
  title="Framing Contractor Software | $79/mo Flat | BuildWorkPro"
  description="Framing contractor software for bidding lumber packages, scheduling crews by building, and billing per unit. $79/month flat, unlimited users, 14-day free trial."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">
          For Framing Contractors
        </p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Framing Contractor Software
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Manage wall layouts, floor systems, and roof framing across all your jobs from one
          platform. Price lumber packages at current quotes, schedule crews for each building or
          phase, track material deliveries, and submit pay apps tied to your percent complete.
        </p>
        <div class="mt-8">
          <a
            href={config.signupUrl}
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
            >Start free trial</a
          >
          <p class="mt-3 text-sm text-slate-400">14-day free trial. No credit card required.</p>
        </div>
      </div>
    </section>

    <!-- Why framing contractors use BuildWorkPro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">
        Why framing contractors use BuildWorkPro
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 21h19.5M3.75 3v18m16.5-18v18M5.25 3h13.5M5.25 21h13.5M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Organize by building and phase
          </h3>
          <p class="text-sm text-slate-500">
            Break multi-building projects into phases and tasks — layout, wall framing, floor
            systems, roof trusses, sheathing — per building or unit. Task dependencies and the Gantt
            view in <a href="/features/project-management/" class="text-brand-600 hover:underline"
              >project management</a
            > show what's framed, what's next, and where every crew stands.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Price lumber packages that hold up
          </h3>
          <p class="text-sm text-slate-500">
            Build <a href="/features/construction-bidding/" class="text-brand-600 hover:underline"
              >bids</a
            > with line items split into material and labor — stud counts, truss packages, hardware, and
            your production rates for layout, standing walls, and roof framing. Import your supplier's
            CSV price list so volatile lumber quotes hit the bid at this week's numbers, not last month's.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H6.375m11.25 0h3.375a1.125 1.125 0 001.125-1.125V14.25m0 0V5.625m0 8.625h-3.75m0 0a1.5 1.5 0 01-1.5-1.5V5.625m5.25 0h-5.25m0 0H9.375m0 0H3.375m6 0V3.75m0 1.875h5.25"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Track lumber deliveries</h3>
          <p class="text-sm text-slate-500">
            Log lumber drops, truss deliveries, and hardware shipments in <a
              href="/features/site-logs/"
              class="text-brand-600 hover:underline">site logs</a
            > under Materials Received, tagged Delivery, with photos from the site. Know what's on the
            ground before the crew shows up — not after they're standing around waiting on a truck.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Bill per building or per unit</h3>
          <p class="text-sm text-slate-500">
            Build AIA-style <a
              href="/features/pay-applications/"
              class="text-brand-600 hover:underline">pay applications</a
            > on a schedule of values with a line per building, unit, or phase. Bill first-floor walls,
            second-floor deck, and roof framing separately, with percent complete and retainage tracked
            per line.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Know where every crew hour went
          </h3>
          <p class="text-sm text-slate-500">
            Crews log hours against a specific project and task with <a
              href="/features/time-tracking/"
              class="text-brand-600 hover:underline">time tracking</a
            >, so labor on Building 3 doesn't blur into Building 4. Review and approve hours by job,
            and compare actual framing labor against what you bid.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Inspection-ready daily records
          </h3>
          <p class="text-sm text-slate-500">
            Record work performed, nailing and shear wall details, and inspector visits in daily
            site logs tagged Inspection, with photos attached. When a question comes up about a unit
            months later, the record is already there.
          </p>
        </div>
      </div>
    </section>

    <!-- Product proof -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 space-y-12">
      <Screenshot
        src="/screenshots/solutions/framing/project-gantt.png"
        alt="BuildWorkPro Gantt chart showing project phases and tasks with dependencies"
        caption="The Gantt schedule: layout, walls, floor systems, and roof sequenced per building, with task dependencies so the plan shifts when a truss delivery slips."
      />
      <Screenshot
        src="/screenshots/solutions/framing/bid-detail-overview.png"
        alt="BuildWorkPro bid detail page showing line items with material and labor cost breakdowns and totals"
        caption="A framing bid: lumber package and labor split into material and labor cost items, with margin and overhead applied on the Rates tab."
      />
    </section>

    <!-- What's included -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-8">
        Everything you need at one flat price
      </h2>
      <p class="text-center text-slate-500 mb-8">
        $79/month for unlimited users and projects. No per-user fees.
      </p>
      <div class="grid sm:grid-cols-2 gap-3">
        {
          included.map((item) => (
            <div class="flex items-center gap-2.5">
              <svg
                class="w-4 h-4 text-brand-600 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-slate-600">{item}</span>
            </div>
          ))
        }
      </div>
    </section>

    <FAQSection faqs={faqs} />

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        Run every framing job from one system
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        $79/month flat for unlimited users — bidding, scheduling, site logs, time tracking, and pay
        apps included. 14-day free trial, no credit card required.
      </p>
      <a
        href={config.signupUrl}
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
        >Start free trial</a
      >
      <p class="mt-8 text-sm text-slate-400">
        Comparing platforms? See how BuildWorkPro stacks up as a
        <a href="/compare/procore-alternative/" class="text-brand-600 hover:underline"
          >Procore alternative</a
        >
        or a
        <a href="/compare/buildertrend-alternative/" class="text-brand-600 hover:underline"
          >Buildertrend alternative</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
