---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Project Management Software for Concrete Contractors | BuildWorkPro" description="Construction software for concrete subcontractors. Manage pours, track projects, handle pay apps and change orders. $79/month, unlimited users.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">For Concrete Contractors</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Project Management for Concrete Contractors
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          From footings to flatwork, manage every pour and every project in one place. Coordinate forming crews, track weather windows for placement days, and submit pay apps that match your schedule of values. BuildWorkPro handles the office work so you can focus on the concrete.
        </p>
        <div class="mt-8">
          <!-- TODO: Restore "Start free trial" button at launch -->
          <button data-request-access class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg">Request Access</button>
          <p class="mt-3 text-sm text-slate-400">Pre-launch access available for select contractors.</p>
        </div>
      </div>
    </section>

    <!-- Why concrete contractors use BuildWorkPro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">Why concrete contractors use BuildWorkPro</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Schedule pours around weather</h3>
          <p class="text-sm text-slate-500">Plan placement days, cure times, and stripping schedules on a visual timeline. When rain pushes a pour, drag it on the Gantt chart and the rest of the schedule adjusts automatically.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Bid with accurate yardage rates</h3>
          <p class="text-sm text-slate-500">Build bids by phase -- footings, walls, slabs, elevated decks, flatwork. Include forming, rebar, placement, and finishing as separate line items with your standard crew rates and mix costs.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Track forming and rebar phases</h3>
          <p class="text-sm text-slate-500">Break each project into forming, rebar/embed, pre-pour inspection, placement, and strip/patch phases. Track percent complete for each and know exactly where your crews need to be.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Pay apps by pour and phase</h3>
          <p class="text-sm text-slate-500">Generate pay applications tied to your schedule of values. Bill separately for foundations, structural walls, elevated slabs, and site concrete with retainage and stored material tracking built in.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Coordinate forming and finishing crews</h3>
          <p class="text-sm text-slate-500">Assign carpenters, rod busters, and finishers across jobs. See who is forming on one site while another crew is placing, and avoid scheduling conflicts on back-to-back pour days.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Daily logs with pour records</h3>
          <p class="text-sm text-slate-500">Log daily crew counts, yards placed, mix design numbers, weather conditions, and cure protection methods. Build a paper trail that protects you on every job.</p>
        </div>
      </div>
    </section>

    <!-- What's included -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-8">Everything you need at one flat price</h2>
      <p class="text-center text-slate-500 mb-8">$79/month for unlimited users and projects. No per-user fees.</p>
      <div class="grid sm:grid-cols-2 gap-3">
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Unlimited users</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Unlimited projects</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Bids & estimates</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Pay applications</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Change orders</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Site logs & daily reports</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Gantt charts & scheduling</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Sales pipeline & CRM</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Time tracking</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Role-based permissions</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Reports & analytics</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-600">Document management</span>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Ready to streamline your concrete business?</h2>
      <p class="text-lg text-slate-500 mb-8">Join other concrete contractors who've ditched spreadsheets for BuildWorkPro.</p>
      <!-- TODO: Restore "Start free trial" button at launch -->
      <button data-request-access class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg">Request Access</button>
    </section>
  </main>
  <Footer />
</Layout>
