---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const included = [
  'Unlimited users',
  'Unlimited projects',
  'Bids & estimates',
  'Pay applications',
  'Change orders',
  'Site logs & daily reports',
  'Gantt charts & scheduling',
  'Sales pipeline & CRM',
  'Time tracking',
  'Role-based permissions',
  'Reports & analytics',
  'Document management',
];

const faqs = [
  {
    question: 'What is the best software for concrete contractors?',
    answer:
      'For structural and flatwork concrete subcontractors working for GCs, BuildWorkPro covers the whole job cycle in one tool: line-item bids, phase-based pour scheduling, daily site logs, change orders, and AIA-style pay applications. It costs $79/month flat with unlimited users, so estimators, project managers, and field crews all work from the same numbers without per-seat fees. Most alternatives are built for GCs or homebuilders and treat the pay-app workflow concrete subs bill through as an afterthought.',
  },
  {
    question: 'Can I document pours, deliveries, and inspections?',
    answer:
      'Yes. Site logs record personnel on site, work performed, materials received, visitors, and issues — so a pour day captures the crew, the work placed, and every mix delivery in one entry. Tag entries as Delivery or Inspection to find them fast later, and attach photos of forms, embeds, and finished slabs. A restricted field-crew role lets workers file logs without seeing bids or billing.',
  },
  {
    question: 'How do I bill for completed pours each month?',
    answer:
      'Create an AIA-style pay application with a schedule of values broken out the way you build — footings, walls, elevated decks, slab-on-grade, site concrete. Each billing period, enter the work completed against each line and BuildWorkPro calculates the amount due with retainage withheld. Approval statuses track every pay app from draft through approved to paid.',
  },
  {
    question: 'Can I price pump time, mobilization, and winter protection into a bid?',
    answer:
      "Yes. Pump time, blankets, and heat go in as line items split into material, labor, and other costs, while job-wide costs like mobilization, pump rental, and permits go in as bid-level project costs that BuildWorkPro spreads across your line items' sell prices. Nothing rides for free, and the GC sees a clean PDF proposal instead of your cost breakdown.",
  },
  {
    question: 'How much does BuildWorkPro cost?',
    answer:
      'One plan: $79/month, or $790/year. That includes unlimited users, unlimited projects, and every module — bidding, pay applications, change orders, site logs, scheduling, time tracking, and CRM. The 14-day free trial requires no credit card.',
  },
];
---

<Layout
  title="Concrete Contractor Software — $79/month Flat | BuildWorkPro"
  description="Bid, schedule, and bill concrete work in one tool — line-item estimates, pour scheduling, site logs, and AIA-style pay apps. $79/month flat, free 14-day trial."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">
          For Concrete Contractors
        </p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Concrete Contractor Software
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          From footings to flatwork, run every pour and every project in one place. Bid the work by
          line item, schedule placement days by phase, log deliveries and inspections, and submit
          pay apps that match your schedule of values. BuildWorkPro handles the office work so you
          can focus on the concrete.
        </p>
        <div class="mt-8">
          <a
            href={config.signupUrl}
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
            >Start free trial</a
          >
          <p class="mt-3 text-sm text-slate-400">14-day free trial. No credit card required.</p>
        </div>
      </div>
    </section>

    <!-- Why concrete contractors use BuildWorkPro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">
        Why concrete contractors use BuildWorkPro
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Schedule footings, walls, and slabs as phases
          </h3>
          <p class="text-sm text-slate-500">
            Break each job into phases and tasks with dependencies, so forming, rebar, pre-pour
            inspection, and placement stay in order on the
            <a href="/features/project-management/" class="text-brand-600 hover:underline"
              >Gantt chart</a
            >. When a pour date moves, the dependencies show exactly what moves with it.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Price yardage, pump time, and rebar per line
          </h3>
          <p class="text-sm text-slate-500">
            Build <a href="/features/construction-bidding/" class="text-brand-600 hover:underline"
              >bids</a
            > by phase — footings, walls, slabs, flatwork — with forming, rebar, placement, and finishing
            as line items split into material, labor, and other costs. Mobilization, pump rental, and
            permits go in as bid-level costs spread across your sell prices.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">
            Pour records, deliveries, and inspections
          </h3>
          <p class="text-sm text-slate-500">
            Log who was on site, work performed, and every mix delivery under Materials Received.
            Tag entries as Delivery or Inspection, note issues, and attach photos — your
            <a href="/features/site-logs/" class="text-brand-600 hover:underline">site logs</a>
            become the paper trail that settles disputes.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Bill by pour and phase</h3>
          <p class="text-sm text-slate-500">
            Generate AIA-style
            <a href="/features/pay-applications/" class="text-brand-600 hover:underline"
              >pay applications</a
            > from a schedule of values broken out by foundations, structural walls, elevated slabs, and
            site concrete. Retainage is calculated on every line, and approval statuses track each pay
            app to paid.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3h-6M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Get paid for T&M extras</h3>
          <p class="text-sm text-slate-500">
            Out-of-scope work — added footings, washout moves, rock excavation — becomes a
            <a href="/features/change-orders/" class="text-brand-600 hover:underline"
              >change order</a
            > with priced line items and an approval flow. Approved change orders roll into the contract
            sum, so your next pay application reflects the new total.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-2.5 rounded-xl bg-brand-50 mb-4">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Know where crew hours went</h3>
          <p class="text-sm text-slate-500">
            Crews log hours against specific projects and tasks, and every entry carries a review
            status so the office checks time before payroll. A restricted field-crew role lets
            workers file logs and hours without seeing bids or billing.
          </p>
        </div>
      </div>
    </section>

    <!-- Product proof -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 space-y-10">
      <Screenshot
        src="/screenshots/solutions/concrete/project-phases-tasks.png"
        alt="BuildWorkPro project phases and tasks view showing a construction job broken into sequenced phases"
        caption="A job broken into phases — forming, rebar, inspection, placement — with tasks, dependencies, and percent complete per phase."
      />
      <Screenshot
        src="/screenshots/solutions/concrete/site-logs-list.png"
        alt="BuildWorkPro site logs list showing daily log entries with tags and personnel counts"
        width={1920}
        height={1080}
        caption="Site logs in one list: every pour day, mix delivery, and inspection tagged and dated, so the record is there when questions come up."
      />
    </section>

    <!-- What's included -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-8">
        Everything you need at one flat price
      </h2>
      <p class="text-center text-slate-500 mb-8">
        $79/month for unlimited users and projects. No per-user fees.
      </p>
      <div class="grid sm:grid-cols-2 gap-3">
        {
          included.map((item) => (
            <div class="flex items-center gap-2.5">
              <svg
                class="w-4 h-4 text-brand-600 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-slate-600">{item}</span>
            </div>
          ))
        }
      </div>
    </section>

    <FAQSection faqs={faqs} />

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        Run your concrete work from one tool
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        Bids, pay apps, change orders, site logs, scheduling, and time tracking — $79/month flat,
        unlimited users. 14-day free trial, no credit card required.
      </p>
      <a
        href={config.signupUrl}
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
        >Start free trial</a
      >
      <p class="mt-8 text-sm text-slate-400">
        Comparing platforms? See how BuildWorkPro stacks up as a
        <a href="/compare/procore-alternative/" class="text-brand-600 hover:underline"
          >Procore alternative</a
        >
        or a
        <a href="/compare/buildertrend-alternative/" class="text-brand-600 hover:underline"
          >Buildertrend alternative</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
