---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="BuildWorkPro vs Buildertrend – Built for Subcontractors, Not GCs" description="Buildertrend is built for general contractors. BuildWorkPro is purpose-built for subcontractors with bidding, pay apps, and field tools at $79/month flat.">
  <Header />
  <main class="pt-32 pb-20">

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Compare</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Looking for a Buildertrend Alternative?
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Buildertrend is a great tool for general contractors and home builders. But if you're a subcontractor, you need a platform designed around your workflows — bidding, pay apps, change orders, and field operations. BuildWorkPro delivers all of that at one flat price.
        </p>
      </div>
    </section>

    <!-- Comparison table -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="rounded-2xl border border-slate-200 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-50">
              <th class="text-left px-6 py-4 font-semibold text-slate-900">Feature</th>
              <th class="text-center px-6 py-4 font-semibold text-brand-600">BuildWorkPro</th>
              <th class="text-center px-6 py-4 font-semibold text-slate-400">Buildertrend</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <tr>
              <td class="px-6 py-4 text-slate-700">Built for</td>
              <td class="px-6 py-4 text-center font-semibold text-brand-600">Subcontractors</td>
              <td class="px-6 py-4 text-center text-slate-400">GCs & Home Builders</td>
            </tr>
            <tr class="bg-slate-50/50">
              <td class="px-6 py-4 text-slate-700">Pricing</td>
              <td class="px-6 py-4 text-center font-semibold text-brand-600">$79/month flat</td>
              <td class="px-6 py-4 text-center text-slate-400">From $499/month</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-slate-700">Users</td>
              <td class="px-6 py-4 text-center font-semibold text-brand-600">Unlimited</td>
              <td class="px-6 py-4 text-center text-slate-400">Unlimited (on higher tiers)</td>
            </tr>
            <tr class="bg-slate-50/50">
              <td class="px-6 py-4 text-slate-700">Bidding & Estimates</td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-slate-700">Pay Applications</td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
              <td class="px-6 py-4 text-center text-slate-400">Limited</td>
            </tr>
            <tr class="bg-slate-50/50">
              <td class="px-6 py-4 text-slate-700">Change Orders</td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-slate-700">Site Logs</td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
            </tr>
            <tr class="bg-slate-50/50">
              <td class="px-6 py-4 text-slate-700">Time Tracking</td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-slate-700">CRM & Pipeline</td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
              <td class="px-6 py-4 text-center text-slate-400">Basic lead management</td>
            </tr>
            <tr class="bg-slate-50/50">
              <td class="px-6 py-4 text-slate-700">Gantt Charts</td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center gap-1.5 text-emerald-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Yes
                </span>
              </td>
            </tr>
            <!-- TODO: Restore QuickBooks row at launch -->
            <tr class="bg-slate-50/50">
              <td class="px-6 py-4 text-slate-700">Free Trial</td>
              <!-- TODO: Restore "14 days, no CC" at launch -->
              <td class="px-6 py-4 text-center font-semibold text-brand-600">Coming soon</td>
              <td class="px-6 py-4 text-center text-slate-400">Demo only</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Key differences -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">
          Why subcontractors choose BuildWorkPro
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-8">
        <!-- Card 1 -->
        <div class="rounded-2xl border border-slate-200 bg-white p-8">
          <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Built for subs, not general contractors</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Buildertrend is designed around the GC workflow — client portals, selections, and homeowner communication. BuildWorkPro is built around how subcontractors actually operate: winning bids, managing pay apps, tracking field crews, and getting paid faster.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-2xl border border-slate-200 bg-white p-8">
          <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Flat $79/month — no per-user fees</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Buildertrend starts at $499/month and goes up from there. BuildWorkPro is a flat $79/month with unlimited users. Invite your entire team without worrying about escalating costs as your company grows.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-2xl border border-slate-200 bg-white p-8">
          <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">All features included from day one</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Buildertrend locks features behind their Essential, Advanced, and Complete tiers. With BuildWorkPro, there's one plan with everything included — bidding, pay apps, change orders, CRM, time tracking, Gantt charts, and reports.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="rounded-2xl border border-slate-200 bg-white p-8">
          <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Simple to learn, built for the field</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Buildertrend packs in features for GCs, homeowners, and design teams that subs will never use. BuildWorkPro keeps things focused and clean — your field crews can start logging time and submitting pay apps on day one without extensive training.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="rounded-2xl bg-slate-900 px-8 py-14 sm:px-14">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
          Ready to switch from Buildertrend?
        </h2>
        <!-- TODO: Restore trial CTA at launch -->
        <p class="mt-4 text-slate-400 max-w-xl mx-auto">
          Pre-launch access available for select contractors.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <button data-request-access class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold text-sm cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg">
            Request Access
          </button>
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-white/10 text-white font-semibold text-sm hover:bg-white/20 transition-colors">
            Talk to sales
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
