---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const comparisonRows = [
  {
    label: 'Built for',
    bwp: 'Trade subcontractors working for GCs',
    other: 'Home builders & remodelers selling to homeowners',
    bwpWins: true,
  },
  {
    label: 'Pricing',
    bwp: '$79/month flat, published',
    other: 'Custom quote based on volume (historically ~$339–$499+/month entry)*',
    bwpWins: true,
  },
  {
    label: 'How you buy',
    bwp: 'Self-serve signup, 14-day free trial',
    other: 'Demo and quote process',
    bwpWins: true,
  },
  {
    label: 'Users',
    bwp: 'Unlimited',
    other: 'Unlimited',
    bwpWins: false,
  },
  {
    label: 'Progress billing (schedule of values, retainage)',
    bwp: 'Core feature — AIA-style pay applications',
    other: 'Oriented to residential invoicing and draws',
    bwpWins: true,
  },
  {
    label: 'Bidding for subs',
    bwp: 'Line items, labor rates, markup, PDF proposals to GCs',
    other: 'Proposals oriented to homeowner clients',
    bwpWins: true,
  },
  {
    label: 'Homeowner portal, selections & allowances',
    bwp: 'Not the focus',
    other: 'Industry leader',
    bwpWins: false,
  },
  {
    label: 'Daily logs & time tracking',
    bwp: 'Included',
    other: 'Included',
    bwpWins: false,
  },
  {
    label: 'Sales pipeline & CRM',
    bwp: 'Included',
    other: 'Included',
    bwpWins: false,
  },
  {
    label: 'Setup',
    bwp: 'Same-day — CSV import wizards',
    other: 'Onboarding program, typically weeks',
    bwpWins: true,
  },
];

const faqs = [
  {
    question: 'What is the best Buildertrend alternative for subcontractors?',
    answer:
      'BuildWorkPro. Buildertrend is excellent software for residential builders and remodelers who sell to homeowners, but its client portal, selections, and allowances workflows are built around that business. BuildWorkPro is built for trade subcontractors who bid to GCs and bill monthly against a schedule of values — with bidding, AIA-style pay applications, change orders, site logs, time tracking, and CRM at $79/month flat.',
  },
  {
    question: 'How much does Buildertrend cost compared to BuildWorkPro?',
    answer:
      'As of mid-2026, Buildertrend uses quote-based pricing tied to your construction volume; before that change its published plans started around $339–$499 per month. BuildWorkPro publishes one flat price: $79/month or $790/year with every feature and unlimited users included — roughly a tenth of Buildertrend’s historical entry tier.',
  },
  {
    question: 'Is Buildertrend built for subcontractors?',
    answer:
      'Buildertrend is primarily designed for home builders and remodelers — companies whose client is a homeowner. Its standout features (client portal, selections, allowances, financing tools) serve that relationship. A subcontractor working under GCs has a different workflow: estimate to a GC, win the contract, bill progress monthly with retainage, and document the field. BuildWorkPro is designed around that loop.',
  },
  {
    question: 'Can I switch from Buildertrend to BuildWorkPro?',
    answer:
      'Yes. Export your contacts, leads, and job list, then use BuildWorkPro’s guided CSV import wizards to bring in contacts, leads, products, and projects. The 14-day free trial (no credit card) is enough time to run a real bid and pay application before deciding.',
  },
  {
    question: 'When is Buildertrend the better choice?',
    answer:
      'If you build or remodel homes and your customer is the homeowner, Buildertrend is the stronger platform — the client portal, selections and allowances, daily-log sharing with clients, and consumer financing integrations are all built for that business. BuildWorkPro is the better fit for specialty trade contractors working under GCs on commercial or residential jobs.',
  },
];
---

<Layout
  title="Buildertrend Alternative for Trade Contractors — BuildWorkPro vs Buildertrend"
  description="Buildertrend is built for home builders selling to homeowners. BuildWorkPro is built for trade subs billing GCs — bids, AIA-style pay apps, change orders & CRM at $79/month flat. Full comparison."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Compare</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          The Buildertrend Alternative for Trade Contractors
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Buildertrend is built for home builders and remodelers whose client is a homeowner. If
          your client is a GC — and your month ends with a pay application, not a homeowner invoice
          — you're shopping in the wrong aisle. BuildWorkPro runs the subcontractor's workflow for
          $79/month flat.
        </p>
      </div>
    </section>

    <!-- Verdict box (answer-first for skimmers and AI search) -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <div class="rounded-2xl border border-brand-100 bg-brand-50 p-8">
        <h2 class="text-base font-semibold text-slate-900 mb-3">The short version</h2>
        <p class="text-slate-600 leading-relaxed text-sm">
          <strong>Choose Buildertrend</strong> if you build or remodel homes and need homeowner-facing
          tools: a client portal, selections and allowances, and consumer financing. <strong
            >Choose BuildWorkPro</strong
          > if you're a specialty sub — electrical, plumbing, HVAC, roofing, concrete, framing — who bids
          to GCs, bills monthly against a schedule of values with retainage, and wants published flat
          pricing instead of a quote process.
        </p>
      </div>
    </section>

    <!-- Comparison table -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-10">
        BuildWorkPro vs Buildertrend at a glance
      </h2>
      <div class="rounded-2xl border border-slate-200 overflow-hidden overflow-x-auto">
        <table class="w-full text-sm min-w-[640px]">
          <thead>
            <tr class="bg-slate-50">
              <th class="text-left px-6 py-4 font-semibold text-slate-900 w-1/3"></th>
              <th class="text-left px-6 py-4 font-semibold text-brand-600">BuildWorkPro</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-500">Buildertrend</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {
              comparisonRows.map((row, i) => (
                <tr class={i % 2 === 1 ? 'bg-slate-50/50' : ''}>
                  <td class="px-6 py-4 font-medium text-slate-700">{row.label}</td>
                  <td
                    class={`px-6 py-4 ${row.bwpWins ? 'font-semibold text-brand-700' : 'text-slate-600'}`}
                  >
                    {row.bwp}
                  </td>
                  <td class="px-6 py-4 text-slate-500">{row.other}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-slate-400 px-2">
        *Buildertrend moved to quote-based pricing and no longer publishes plan prices; the range
        reflects its previously published entry tiers and independent reporting as of June 2026.
        Verify current pricing with Buildertrend.
      </p>
    </section>

    <!-- Honest section -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="prose prose-slate max-w-none">
        <h2 class="text-2xl font-bold text-slate-900">Where Buildertrend genuinely wins</h2>
        <p class="text-slate-600">
          For a custom home builder or remodeler, Buildertrend's homeowner-facing tools are the
          point: clients pick finishes through selections and allowances, follow progress in a
          portal, approve change orders, and even arrange financing. If that's your business,
          Buildertrend earns its price.
        </p>
        <p class="text-slate-600">
          None of that machinery helps a trade sub. Your GC doesn't want a selections portal — they
          want a clean bid with labor rates and exclusions, a monthly pay application that matches
          the schedule of values, and change orders priced and approved before the work happens.
          That billing loop — bid → contract → monthly pay app with retainage → closeout — is the
          core of BuildWorkPro, not an adaptation of a homeowner workflow.
        </p>
      </div>
    </section>

    <!-- Product proof -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-4">
        Built around sub-to-GC billing
      </h2>
      <p class="text-center text-slate-500 max-w-2xl mx-auto mb-10">
        Your contract value, change orders, schedule of values, and retainage stay connected from
        the first estimate to the final pay app.
      </p>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <Screenshot
            src="/screenshots/12-pay-apps-list.png"
            alt="BuildWorkPro pay applications list showing billing periods, amounts, and approval status"
            caption="Every pay application across every project and GC, with status from draft to paid."
            width={1280}
            height={720}
          />
        </div>
        <div>
          <Screenshot
            src="/screenshots/09-change-order-detail.png"
            alt="BuildWorkPro change order detail with scope, pricing, and approval workflow"
            caption="Change orders priced, submitted, and approved — your contract value stays current."
          />
        </div>
      </div>
    </section>

    <FAQSection faqs={faqs} />

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="rounded-2xl bg-slate-900 px-8 py-14 sm:px-14">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
          Software that matches how subs actually get paid
        </h2>
        <p class="mt-4 text-slate-400 max-w-xl mx-auto">
          Every feature, unlimited users, $79/month flat. 14-day free trial — no credit card, no
          demo call.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={config.signupUrl}
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold text-sm transition-all hover:-translate-y-0.5 hover:shadow-lg"
          >
            Start free trial
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-white/10 text-white font-semibold text-sm hover:bg-white/20 transition-colors"
          >
            Talk to us
          </a>
        </div>
        <p class="mt-6 text-sm text-slate-500">
          Comparing GC platforms too? See
          <a href="/compare/procore-alternative/" class="text-slate-300 underline hover:text-white"
            >BuildWorkPro vs Procore</a
          >.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
