    items: [
      { label: 'Creating a bid', href: '/docs/bids/creating-a-bid/' },
      { label: 'Line items', href: '/docs/bids/line-items/' },
      { label: 'Rates', href: '/docs/bids/rates/' },
      { label: 'Bid templates', href: '/docs/bids/templates/' },
      { label: 'Sending a bid', href: '/docs/bids/sending/' },
    ],
  },
  {
    title: 'Products & Catalog',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
    items: [
      { label: 'Product catalog', href: '/docs/products/catalog/' },
      { label: 'Product kits', href: '/docs/products/kits/' },
    ],
  },
  {
    title: 'Project Management',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
    items: [
      { label: 'Projects overview', href: '/docs/projects/overview/' },
      { label: 'Phases & tasks', href: '/docs/projects/phases-tasks/' },
      { label: 'Gantt chart', href: '/docs/projects/gantt/' },
      { label: 'Project templates', href: '/docs/projects/templates/' },
      {
        label: 'Documents, comments & activity',
        href: '/docs/projects/documents-comments-activity/',
      },
    ],
  },
  {
    title: 'Pay Applications',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    items: [
      { label: 'Creating a pay app', href: '/docs/pay-apps/creating/' },
      { label: 'Schedule of values', href: '/docs/pay-apps/schedule-of-values/' },
      { label: 'Approval workflow', href: '/docs/pay-apps/approval-workflow/' },
      { label: 'PDF & email', href: '/docs/pay-apps/pdf-and-email/' },
    ],
  },
  {
    title: 'Change Orders',
    icon: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
    items: [
      { label: 'Creating a change order', href: '/docs/change-orders/creating/' },
      { label: 'Change order approval', href: '/docs/change-orders/approval/' },
    ],
  },
  {
    title: 'Field Operations',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
    items: [
      { label: 'Site logs', href: '/docs/field/site-logs/' },
      { label: 'Time tracking', href: '/docs/field/time-tracking/' },
