---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { config } from '../config';

const categories = [
  {
    title: 'Getting Started',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    items: [
      { label: 'What is BuildWorkPro?', href: '/docs/getting-started/introduction/' },
      { label: 'Quick start', href: '/docs/getting-started/quick-start/' },
      { label: 'Your first project', href: '/docs/getting-started/first-project/' },
      { label: 'Your dashboard', href: '/docs/getting-started/dashboard/' },
      { label: 'Navigation & search', href: '/docs/getting-started/navigation-and-search/' },
    ],
  },
  {
    title: 'CRM & Pipeline',
    icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
    items: [
      { label: 'Contacts', href: '/docs/crm/contacts/' },
      { label: 'Leads', href: '/docs/crm/leads/' },
      { label: 'Sales pipeline', href: '/docs/crm/pipeline/' },
