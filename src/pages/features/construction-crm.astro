---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Construction CRM & Sales Pipeline Software | BuildWorkPro" description="Manage leads, contacts, and your sales pipeline with a visual Kanban board. Track deal values, follow-ups, and win rates. CRM built for subcontractors.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Features</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Construction CRM & Sales Pipeline
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Stop losing leads to sticky notes and spreadsheets. BuildWorkPro gives you a visual pipeline to track every opportunity from first contact through bid submission, with contact management, deal tracking, and follow-up reminders built in.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <!-- TODO: Restore "Start free trial" button at launch -->
          <button data-request-access class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg">
            Request Access
          </button>
          <a href="/features/" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-slate-700 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
            All features
          </a>
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="prose prose-lg prose-slate mx-auto">
        <h2>Win more work by managing your pipeline</h2>
        <p>
          Most subcontractors track their sales pipeline in their head or on a whiteboard. When you are juggling ITBs from multiple GCs, referrals from past clients, and cold leads from plan rooms, things fall through the cracks. BuildWorkPro gives you a dedicated CRM designed for how subcontractors sell -- relationship-driven, bid-focused, and tied directly to your estimating workflow.
        </p>
        <p>
          Every contact, lead, and opportunity lives in one system. When a lead turns into a bid, the data flows through. When a bid is won, it becomes a project. No re-entering information, no disconnected spreadsheets, no lost context.
        </p>
      </div>
    </section>

    <!-- Key Capabilities -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">Key capabilities</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-emerald-50 ring-1 ring-emerald-100 mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Contact management</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Centralized database for GCs, owners, architects, and vendors. Store addresses, phone numbers, emails, notes, and tags. Link contacts to projects, bids, and leads.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-emerald-50 ring-1 ring-emerald-100 mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125c-.621 0-1.125.504-1.125 1.125v12.75c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Kanban pipeline</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Visual drag-and-drop pipeline with customizable stages -- New Lead, Contacted, Bid Invited, Bid Submitted, Negotiation, Won, Lost. See your entire sales funnel at a glance.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-emerald-50 ring-1 ring-emerald-100 mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Deal tracking</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Assign deal values and probability to every opportunity. Track your weighted pipeline value so you can forecast revenue and plan your bidding capacity.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-emerald-50 ring-1 ring-emerald-100 mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Follow-up reminders</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Set follow-up dates on leads and get reminders when it is time to reach out. Never let an opportunity go cold because you forgot to follow up after a bid submission.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-emerald-50 ring-1 ring-emerald-100 mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Lead sources</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Tag leads by source -- referral, plan room, repeat client, website. Track which channels bring you the most work so you can focus your business development effort.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-emerald-50 ring-1 ring-emerald-100 mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Lead-to-bid conversion</h3>
          <p class="text-sm text-slate-500 leading-relaxed">When a lead becomes an active opportunity, convert it into a bid with one click. Contact information, project details, and notes carry over automatically.</p>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- TODO: Restore "Ready to get started?" CTA with trial button at launch -->
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Ready to get started?</h2>
      <p class="text-lg text-slate-500 mb-8">Pre-launch access available for select contractors.</p>
      <button data-request-access class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg">
        Request Access
      </button>
    </section>
  </main>
  <Footer />
</Layout>
