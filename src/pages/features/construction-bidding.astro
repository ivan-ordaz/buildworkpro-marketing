---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const faqs = [
  {
    question: 'What is construction bidding software?',
    answer:
      'Construction bidding software replaces spreadsheet estimating with structured bids: line items broken into material, labor, and other costs; margin, overhead, and commission applied consistently; and a professional PDF proposal generated from the same numbers. In BuildWorkPro, every bid also tracks its status — draft, sent, accepted, or rejected — and a won bid converts directly into a project.',
  },
  {
    question: 'How does BuildWorkPro handle labor and material pricing?',
    answer:
      'Every line item breaks down into cost items typed as Material, Labor, or Other, each with its own cost, sell price, and tax settings. You can pull items from a reusable product catalog instead of retyping prices, and import vendor price lists from CSV with reusable column mappings.',
  },
  {
    question: 'Can I reuse estimates from past jobs?',
    answer:
      'Yes, two ways. Duplicate any past bid as a starting point, or save a bid template that captures your estimate structure, payment terms, and conditions — so repeat work starts 80% done instead of from a blank page.',
  },
  {
    question: 'How do markup, overhead, and bid-level costs work?',
    answer:
      "The Rates tab sets the margin, commission, and overhead applied to the bid, so your sell price is systematic instead of guessed. Job-wide costs like mobilization, a dumpster, or permits go in Project Costs, and BuildWorkPro spreads them across your line items' sell prices automatically.",
  },
  {
    question: 'What happens when I win the bid?',
    answer:
      'Convert the accepted bid into an active project in one click. The contract value carries into the project, and when you create your first pay application, the original contract sum and schedule of values prefill from the bid — no re-entering numbers.',
  },
  {
    question: 'How much does it cost?',
    answer:
      'Bidding is included in the single BuildWorkPro plan: $79/month (or $790/year) with unlimited users, unlimited projects, and every feature. There is a 14-day free trial with no credit card required.',
  },
];
---

<Layout
  title="Construction Bidding & Estimating Software for Subcontractors | BuildWorkPro"
  description="Build line-item bids with material, labor, and overhead costs, apply margin systematically, send PDF proposals, and convert wins into projects. $79/month flat, 14-day free trial."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Features</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Construction Bidding & Estimating Software
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Build accurate bids with line items broken into material, labor, and other costs. Apply
          margin, overhead, and commission systematically, send a polished PDF proposal, and convert
          the win straight into a project — all from one platform.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={config.signupUrl}
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
          >
            Start free trial
          </a>
          <a
            href="/features/"
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-slate-700 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all"
          >
            All features
          </a>
        </div>
      </div>
    </section>

    <!-- Product proof -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <Screenshot
        src="/screenshots/05-bid-detail-overview.png"
        alt="BuildWorkPro bid detail page showing the estimate with line items, cost breakdowns, and bid totals"
        caption="A bid in BuildWorkPro: line items with material, labor, and other cost breakdowns, totals updating as you build."
      />
    </section>

    <!-- Overview -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="prose prose-lg prose-slate mx-auto">
        <h2>Stop losing money on inaccurate bids</h2>
        <p>
          For subcontractors, every bid is a balancing act. Price too high and you lose the job.
          Price too low and you eat into your margin on every hour worked. BuildWorkPro gives you
          structured estimating so you break down costs by material, labor, and other expense — then
          apply margin, overhead, and commission on the
          <a href="/docs/bids/rates/">Rates tab</a> instead of guessing a single markup number.
        </p>
        <p>
          Every bid lives in your system as a permanent record. You track which bids were sent,
          which are pending, and which you won or lost. Over time your bid history becomes the
          dataset for sharper pricing — and the starting point for the next estimate, since any bid
          can be <a href="/docs/bids/pdf-and-duplication/">duplicated</a> or saved as a
          <a href="/docs/bids/templates/">template</a> with your payment terms and conditions.
        </p>
        <p>
          New to structured bidding? Our guide on
          <a href="/blog/how-to-create-construction-bid/">how to create a construction bid</a>
          walks through the full process, from takeoff to proposal.
        </p>
      </div>
    </section>

    <!-- Key Capabilities -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">
        Key capabilities
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-violet-50 ring-1 ring-violet-100 mb-4">
            <svg
              class="w-6 h-6 text-violet-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Line items with cost detail</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Each line item breaks down into cost items for material, labor, and other costs — with
            quantities, units, buy and sell tax, and per-line totals that roll up live.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-violet-50 ring-1 ring-violet-100 mb-4">
            <svg
              class="w-6 h-6 text-violet-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Reusable product catalog</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Price bids from a catalog of materials, labor, and kits with SKUs, costs, and sell
            prices. Add an item once, pull it into every bid — or import vendor price lists from CSV
            with reusable column mappings.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-violet-50 ring-1 ring-violet-100 mb-4">
            <svg
              class="w-6 h-6 text-violet-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Margin, overhead & commission</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            The Rates tab turns your costs into a sell price systematically — set margin,
            commission, and overhead once per bid instead of hand-tuning every line.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-violet-50 ring-1 ring-violet-100 mb-4">
            <svg
              class="w-6 h-6 text-violet-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Job-wide project costs</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Mobilization, dumpsters, permits — add costs that apply to the whole job and
            BuildWorkPro spreads them across your line items' sell prices, so nothing rides for
            free.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-violet-50 ring-1 ring-violet-100 mb-4">
            <svg
              class="w-6 h-6 text-violet-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Professional PDF proposals</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Generate clean proposals with your branding, scope, payment terms, and conditions.
            Display options control how much cost detail the GC sees. Send it without leaving
            BuildWorkPro.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-violet-50 ring-1 ring-violet-100 mb-4">
            <svg
              class="w-6 h-6 text-violet-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Bid-to-project conversion</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            When a bid is accepted, convert it into an active project in one click. Your contract
            value flows into the project and prefills the schedule of values on your first
            <a href="/features/pay-applications/" class="text-brand-600 hover:underline"
              >pay application</a
            >.
          </p>
        </div>
      </div>
    </section>

    <!-- Markup screenshot -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <Screenshot
        src="/screenshots/06-bid-detail-marks.png"
        alt="BuildWorkPro bid rates and marks showing margin, commission, and overhead applied to the estimate"
        caption="Margin, commission, and overhead applied once — every line item's sell price stays consistent."
      />
    </section>

    <!-- How It Works -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">How it works</h2>
      <div class="space-y-8">
        <div class="flex gap-4">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold"
          >
            1
          </div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 mb-1">Create a bid</h3>
            <p class="text-slate-500">
              Start from scratch, duplicate a past bid, or load a template with your standard
              estimate structure and terms. Set the customer, project details, and due date.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold"
          >
            2
          </div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 mb-1">Build the estimate</h3>
            <p class="text-slate-500">
              Add line items and break each into material, labor, and other cost items — typed in by
              hand, pulled from your product catalog, or imported from a vendor's CSV price list.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold"
          >
            3
          </div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 mb-1">Set rates and project costs</h3>
            <p class="text-slate-500">
              Apply margin, commission, and overhead on the Rates tab. Add job-wide costs like
              mobilization and permits, and BuildWorkPro distributes them across your sell prices.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold"
          >
            4
          </div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 mb-1">Send, track, and convert</h3>
            <p class="text-slate-500">
              Send the PDF proposal and track status from draft to accepted. Win the job? One click
              converts the bid into a project, ready for scheduling and pay applications.
            </p>
          </div>
        </div>
      </div>
      <p class="mt-10 text-center text-sm text-slate-400">
        Full walkthrough in the docs:
        <a href="/docs/bids/creating-a-bid/" class="text-brand-600 hover:underline"
          >Creating a bid</a
        >
        ·
        <a href="/docs/bids/line-items/" class="text-brand-600 hover:underline">Line items</a>
        ·
        <a href="/docs/bids/sending/" class="text-brand-600 hover:underline">Sending & tracking</a>
      </p>
    </section>

    <FAQSection faqs={faqs} />

    <!-- Bottom CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        Win more work at margins that hold up
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        Bidding is included in the $79/month flat plan — unlimited users, every feature. 14-day free
        trial, no credit card required.
      </p>
      <a
        href={config.signupUrl}
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
      >
        Start free trial
      </a>
    </section>
  </main>
  <Footer />
</Layout>
