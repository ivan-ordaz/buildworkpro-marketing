---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FAQSection from '../../components/FAQSection.astro';
import Screenshot from '../../components/Screenshot.astro';
import { config } from '../../config';

const faqs = [
  {
    question: 'What reports does BuildWorkPro include?',
    answer:
      'BuildWorkPro has four report tabs, each with KPI cards and two charts. Pipeline shows Total Leads, Pipeline Value, Weighted Pipeline, and Won Deals with pipeline-by-stage and win/loss charts. Bids shows Total Bids, Conversion Rate, Total Quoted, and Accepted Value with bids-by-status charts. Projects shows Total Projects, In Progress, Completed, and Total Value with status and value-by-type charts. Activity shows New Contacts and Total Activities with activity-by-type and new-contacts-by-type charts.',
  },
  {
    question: 'Can I export reports?',
    answer:
      'Yes. The Export menu downloads the current report as a CSV, or you can print it to save as a PDF. Whatever period you have selected is what exports, so you can pull this month or year to date without editing anything. Exporting requires the Member role or above.',
  },
  {
    question: 'Where does the report data come from?',
    answer:
      'From the records your team already keeps in BuildWorkPro. Leads feed the Pipeline report, bids feed the Bids report, projects feed the Projects report, and contacts and activities feed the Activity report. There is no separate data entry for reporting — the numbers update as your team works.',
  },
  {
    question: 'Who can run reports?',
    answer:
      'Company Admin, Manager, Member, and Viewer roles can all view reports. Field Crew has no access to the Reports module. Exporting requires Member or above, so a Viewer can look at every report but cannot download the data.',
  },
  {
    question: 'How much does construction reporting software cost?',
    answer:
      'Reports are included in the single BuildWorkPro plan: $79/month (or $790/year) with unlimited users, unlimited projects, and every feature. There is a 14-day free trial with no credit card required.',
  },
];
---

<Layout
  title="Construction Reporting & Analytics Software | BuildWorkPro"
  description="Pipeline, bid, project, and activity reports with KPI cards and charts. Filter by period, export to CSV or PDF. $79/month flat, 14-day free trial."
>
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Features</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Construction Reporting & Analytics
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Pipeline, bid, project, and activity reports built from the records your team already
          keeps. KPI cards and charts, scoped to any period, exported to CSV or PDF — so you know
          how much you quoted, how much you won, and which job types carry the value.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={config.signupUrl}
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
          >
            Start free trial
          </a>
          <a
            href="/features/"
            class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-slate-700 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all"
          >
            All features
          </a>
        </div>
      </div>
    </section>

    <!-- Product proof -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <Screenshot
        src="/screenshots/19-reports.png"
        alt="BuildWorkPro Reports page on the Pipeline tab with KPI cards for Total Leads, Pipeline Value, Weighted Pipeline, and Won Deals, plus pipeline-by-stage and win/loss charts"
        caption="The Pipeline report: KPI cards and charts for the period you pick, with export one click away."
      />
    </section>

    <!-- Overview -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="prose prose-lg prose-slate mx-auto">
        <h2>Replace gut feel with your own numbers</h2>
        <p>
          Most subcontractors find out how the year went when they look at the bank account in
          December. You know which months felt busy — not how much of what you quoted actually
          converted, or which job types carry your contract value. The Reports module turns the data
          you already enter into KPI cards and charts across four tabs: Pipeline, Bids, Projects,
          and Activity.
        </p>
        <p>
          The numbers start where the work starts. Every estimate you build in
          <a href="/features/construction-bidding/">bidding</a> feeds the Bids report — total bids, conversion
          rate, total quoted, and accepted value — so your win rate is a number, not a hunch. And because
          reports live in the same system as your
          <a href="/features/pay-applications/">pay applications</a> and
          <a href="/features/time-tracking/">time tracking</a>, reporting is a byproduct of running
          jobs, not a separate chore.
        </p>
        <p>
          A period selector at the top scopes every report to a date range — this month, year to
          date, and other ranges — and the Export menu downloads what you see. Full details in the
          <a href="/docs/reports/overview/">Reports docs</a>.
        </p>
      </div>
    </section>

    <!-- Key Capabilities -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">
        Key capabilities
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg
              class="w-6 h-6 text-indigo-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Pipeline report</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Total Leads, Pipeline Value, Weighted Pipeline, and Won Deals — with pipeline-by-stage
            and win/loss charts that show how much quoted work is actually in play.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg
              class="w-6 h-6 text-indigo-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z"></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Bids report</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Total Bids, Conversion Rate, Total Quoted, and Accepted Value, with bids-by-status
            charts. Know how often a sent bid turns into a job before you price the next one.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg
              class="w-6 h-6 text-indigo-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Projects report</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Total Projects, In Progress, Completed, and Total Value, with status and value-by-type
            charts — see which job types carry your contract value.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg
              class="w-6 h-6 text-indigo-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Activity report</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            New Contacts and Total Activities, with activity-by-type and new-contacts-by-type
            charts. A quick read on whether business development is actually happening.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg
              class="w-6 h-6 text-indigo-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Period filter</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            One selector scopes every KPI card and chart to a date range — this month, year to date,
            and other ranges. The numbers recalculate for the window you pick.
          </p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg
              class="w-6 h-6 text-indigo-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Export to CSV or PDF</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Open the Export menu to download the current report as a CSV, or print it to save as a
            PDF — hand your accountant the numbers without retyping anything.
          </p>
        </div>
      </div>
    </section>

    <!-- Dashboard screenshot -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <Screenshot
        src="/screenshots/01-dashboard.png"
        alt="BuildWorkPro dashboard with KPI cards for pipeline value, win rate, active projects, and pending bids above a revenue timeline chart"
        caption="The dashboard gives you the KPI overview every time you log in — pipeline value, win rate, active projects, and pending bids."
      />
    </section>

    <!-- How It Works -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">How it works</h2>
      <div class="space-y-8">
        <div class="flex gap-4">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold"
          >
            1
          </div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 mb-1">Run your work as usual</h3>
            <p class="text-slate-500">
              The leads, bids, projects, and contacts your team already records are the report data.
              There is no separate entry step — the reports read what is already there.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold"
          >
            2
          </div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 mb-1">Open Reports and pick a tab</h3>
            <p class="text-slate-500">
              Open Reports from the sidebar and switch between Pipeline, Bids, Projects, and
              Activity. Each tab shows its KPI cards and two charts.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold"
          >
            3
          </div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 mb-1">
              Filter the period and export
            </h3>
            <p class="text-slate-500">
              Scope the report to this month, year to date, or another range, then download it as a
              CSV or print it to save as a PDF from the Export menu.
            </p>
          </div>
        </div>
      </div>
      <p class="mt-10 text-center text-sm text-slate-400">
        Full walkthrough in the docs:
        <a href="/docs/reports/overview/" class="text-brand-600 hover:underline">Reports</a>
        ·
        <a href="/docs/crm/pipeline/" class="text-brand-600 hover:underline">CRM pipeline</a>
        ·
        <a href="/docs/projects/overview/" class="text-brand-600 hover:underline"
          >Projects overview</a
        >
      </p>
    </section>

    <FAQSection faqs={faqs} />

    <!-- Bottom CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        Know your numbers before you bid the next job
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        Reports are included in the $79/month flat plan — unlimited users, every feature. 14-day
        free trial, no credit card required.
      </p>
      <a
        href={config.signupUrl}
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
      >
        Start free trial
      </a>
    </section>
  </main>
  <Footer />
</Layout>
