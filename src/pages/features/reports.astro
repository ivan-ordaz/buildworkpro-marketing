---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Construction Reporting & Analytics Software | BuildWorkPro" description="Real-time dashboards and reports for revenue, project profitability, bid win rates, and team productivity. Data-driven decisions for subcontractors.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Features</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Construction Reports & Analytics
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          See how your business is performing with real-time dashboards and detailed reports. Track revenue, project profitability, bid win rates, and team productivity -- all from data you are already entering into BuildWorkPro.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <!-- TODO: Restore "Start free trial" button at launch -->
          <span class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-slate-400 rounded-xl cursor-default">
            Coming Soon
          </span>
          <a href="/features/" class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-slate-700 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
            All features
          </a>
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="prose prose-lg prose-slate mx-auto">
        <h2>Make decisions based on data, not gut feel</h2>
        <p>
          Most subcontractors know if they had a good year when they check their bank account in December. BuildWorkPro gives you visibility into your business performance in real time -- which jobs are profitable, which are bleeding margin, how your pipeline is trending, and where your revenue is coming from.
        </p>
        <p>
          Because your bids, projects, pay apps, change orders, and time entries all live in one system, BuildWorkPro can surface insights that would take hours to compile from spreadsheets. Your dashboard updates automatically as your team works, so you always have the current picture.
        </p>
      </div>
    </section>

    <!-- Key Capabilities -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 text-center mb-12">Key capabilities</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Dashboard KPIs</h3>
          <p class="text-sm text-slate-500 leading-relaxed">At-a-glance metrics for active projects, pipeline value, outstanding receivables, and revenue. Your dashboard shows what matters most to running your business today.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Revenue reports</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Track billed revenue, collected payments, and outstanding receivables by project, client, and time period. See trends in your monthly and quarterly revenue.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Project profitability</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Compare contract values against labor costs, material expenses, and change orders for every project. Identify your most and least profitable jobs to improve future bidding.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Bid analytics</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Track your bid win rate, average bid size, and bid volume over time. See which types of work and which GCs give you the best hit rate to focus your estimating effort.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Export to CSV</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Export any report to CSV for further analysis in Excel or Google Sheets. Pull the raw data you need for accountants, bonding companies, or bank loan applications.</p>
        </div>

        <div class="p-6 rounded-2xl border border-slate-100 bg-white">
          <div class="inline-flex p-3 rounded-xl bg-indigo-50 ring-1 ring-indigo-100 mb-4">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Custom filters</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Filter reports by date range, project, client, team member, or status. Drill into the specific data you need without wading through information you do not.</p>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- TODO: Restore "Ready to get started?" CTA with trial button at launch -->
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Coming Soon</h2>
      <p class="text-lg text-slate-500 mb-8">We're preparing for launch. Internal testing in progress.</p>
      <span class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-slate-400 rounded-xl cursor-default">
        Coming Soon
      </span>
    </section>
  </main>
  <Footer />
</Layout>
