---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const practices = [
  {
    title: 'Encryption',
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
    items: [
      'TLS 1.3 encryption for all data in transit',
      'AES-256 encryption for data at rest',
      'Encrypted database backups with geographic redundancy',
      'Secure credential storage with bcrypt hashing',
    ],
  },
  {
    title: 'Authentication & Access',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    items: [
      'Two-factor authentication (TOTP)',
      'Role-based access control with 5 permission levels',
      '30+ granular permissions across resource areas',
      'Session management with configurable timeouts',
      'Account lockout after failed login attempts',
    ],
  },
  {
    title: 'Infrastructure',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
    items: [
      'Hosted on enterprise-grade cloud infrastructure',
      'Automated daily backups with point-in-time recovery',
      'DDoS protection and rate limiting',
      'Network isolation and firewall rules',
      'Regular infrastructure patching and updates',
    ],
  },
  {
    title: 'Application Security',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    items: [
      'CSRF protection on all API endpoints',
      'Input validation and sanitization',
      'SQL injection prevention via parameterized queries',
      'XSS protection with content security policies',
      'Dependency vulnerability scanning',
    ],
  },
  {
    title: 'Data Isolation',
    icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4',
    items: [
      'Row-level tenant isolation — your data is never mixed with other organizations',
      'Tenant-scoped API middleware on every request',
      'Separate file storage per organization',
      'Audit logging of all data access and modifications',
    ],
  },
  {
    title: 'Compliance & Practices',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
    items: [
      'Configurable data retention policies',
      'Full audit trail of user actions',
      'Soft delete with recovery period before permanent removal',
      'Data export in standard formats for portability',
      'Regular security reviews and testing',
    ],
  },
];
---

<Layout title="Security - BuildWorkPro" description="How BuildWorkPro protects your construction business data with enterprise-grade security.">
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Security</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Your data is our responsibility
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          BuildWorkPro is built with security at every layer. Your project data, financial records, and business information are protected by enterprise-grade practices.
        </p>
      </div>

      <!-- Key stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
        {[
          { stat: 'TLS 1.3', label: 'Encryption in transit' },
          { stat: 'AES-256', label: 'Encryption at rest' },
          { stat: '2FA', label: 'Two-factor auth' },
          { stat: 'Row-level', label: 'Tenant isolation' },
        ].map((item) => (
          <div class="text-center p-5 rounded-xl bg-slate-50 border border-slate-100">
            <div class="text-lg font-bold text-slate-900">{item.stat}</div>
            <div class="text-xs text-slate-500 mt-1">{item.label}</div>
          </div>
        ))}
      </div>

      <!-- Security practices -->
      <div class="grid md:grid-cols-2 gap-8">
        {practices.map((practice) => (
          <div class="p-6 rounded-2xl border border-slate-100 bg-white">
            <div class="flex items-center gap-3 mb-4">
              <div class="inline-flex p-2.5 rounded-xl bg-brand-50">
                <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={practice.icon} />
                </svg>
              </div>
              <h3 class="text-base font-semibold text-slate-900">{practice.title}</h3>
            </div>
            <ul class="space-y-2.5">
              {practice.items.map((item) => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-brand-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-sm text-slate-600">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Responsible disclosure -->
      <div class="mt-16 p-8 rounded-2xl bg-slate-50 border border-slate-100 text-center">
        <h2 class="text-xl font-semibold text-slate-900 mb-3">Responsible Disclosure</h2>
        <p class="text-sm text-slate-500 max-w-xl mx-auto mb-4">
          If you discover a security vulnerability, we want to hear from you. Please report it responsibly so we can address it promptly.
        </p>
        <a href="mailto:security@buildworkpro.com" class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-medium text-sm">
          security@buildworkpro.com
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

    </div>

    <div class="mt-16">
      <CTA />
    </div>
  </main>
  <Footer />
</Layout>
