---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact BuildWorkPro – Sales, Support & Partnerships" description="Contact BuildWorkPro for sales inquiries, support, or partnership opportunities. We respond within 24 hours.">
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Contact</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Get in touch
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Have a question about BuildWorkPro? We'd love to hear from you.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact form -->
        <div>
          <form class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Name</label>
              <input type="text" placeholder="Your name" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
              <input type="email" placeholder="you@company.com" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Company</label>
              <input type="text" placeholder="Your company name" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Message</label>
              <textarea rows="4" placeholder="How can we help?" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none"></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" id="gdpr-consent" required class="mt-0.5 h-4 w-4 rounded border-slate-200 text-brand-600 focus:ring-2 focus:ring-brand-500" />
              <label for="gdpr-consent" class="text-sm text-slate-600">
                I agree to the processing of my personal data as described in the <a href="/privacy" class="text-brand-600 hover:text-brand-700 font-medium underline">Privacy Policy</a>.
              </label>
            </div>
            <button type="submit" class="w-full py-3 px-6 rounded-xl bg-brand-600 text-white font-semibold text-sm hover:bg-brand-700 transition-colors">
              Send message
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="space-y-8">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-3">Email us</h3>
            <a href="mailto:hello@buildworkpro.com" class="text-brand-600 hover:text-brand-700 font-medium">
              hello@buildworkpro.com
            </a>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-3">Support</h3>
            <a href="/support" class="text-brand-600 hover:text-brand-700 font-medium">
              Visit our support center
            </a>
            <p class="text-sm text-slate-500 mt-1">For existing customers with technical questions.</p>
          </div>
          <!-- TODO: Restore "Try it free" section with trial link at launch -->
          <div>
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-3">Early Access</h3>
            <p class="text-sm text-slate-500 mb-3">
              Pre-launch access available for select contractors.
            </p>
            <button data-request-access class="text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 px-5 py-2.5 rounded-lg cursor-pointer transition-all hover:-translate-y-0.5">
              Request Access
            </button>
          </div>
        </div>
      </div>

    </div>
  </main>
  <Footer />
</Layout>
