---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { config } from '../config';
---

<Layout title="Contact BuildWorkPro – Sales, Support & Partnerships" description="Contact BuildWorkPro for sales inquiries, support, or partnership opportunities. We respond within 24 hours.">
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Contact</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Get in touch
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Have a question about BuildWorkPro? We'd love to hear from you.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact form -->
        <div>
          <form id="contact-form" class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Name</label>
              <input type="text" name="name" required placeholder="Your name" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
              <input type="email" name="email" required placeholder="you@company.com" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Company</label>
              <input type="text" name="company" placeholder="Your company name" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">Message</label>
              <textarea name="message" required rows="4" placeholder="How can we help?" class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none"></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" id="gdpr-consent" required class="mt-0.5 h-4 w-4 rounded border-slate-200 text-brand-600 focus:ring-2 focus:ring-brand-500" />
              <label for="gdpr-consent" class="text-sm text-slate-600">
                I agree to the processing of my personal data as described in the <a href="/privacy/" class="text-brand-600 hover:text-brand-700 font-medium underline">Privacy Policy</a>.
              </label>
            </div>
            <div id="contact-turnstile"></div>
            <div id="contact-status" class="hidden text-sm rounded-lg px-4 py-3"></div>
            <button type="submit" id="contact-submit" class="w-full py-3 px-6 rounded-xl bg-brand-600 text-white font-semibold text-sm hover:bg-brand-700 transition-colors">
              Send message
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="space-y-8">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-3">Email us</h3>
            <a href={`mailto:${config.email.hello}`} class="text-brand-600 hover:text-brand-700 font-medium">
              {config.email.hello}
            </a>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-3">Support</h3>
            <a href="/support/" class="text-brand-600 hover:text-brand-700 font-medium">
              Visit our support center
            </a>
            <p class="text-sm text-slate-500 mt-1">For existing customers with technical questions.</p>
          </div>
          <!-- TODO: Restore "Try it free" section with trial link at launch -->
          <div>
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-3">Early Access</h3>
            <p class="text-sm text-slate-500 mb-3">
              Pre-launch access available for select contractors.
            </p>
            <button data-request-access class="text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 px-5 py-2.5 rounded-lg cursor-pointer transition-all hover:-translate-y-0.5">
              Request Access
            </button>
          </div>
        </div>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  declare const turnstile: any;

  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-status');
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const container = document.getElementById('contact-turnstile');
    if (!form || !status || !submitBtn || !container) return;

    const sitekey = document.body.dataset.turnstileSitekey;
    let turnstileToken = '';
    let widgetId: string | undefined;

    function renderWidget() {
      if (typeof turnstile === 'undefined' || widgetId !== undefined) return;
      widgetId = turnstile.render(container, {
        sitekey,
        callback: (token: string) => { turnstileToken = token; },
        'expired-callback': () => { turnstileToken = ''; },
        theme: 'light',
      });
    }

    // Render when Turnstile script loads (may already be loaded)
    if (typeof turnstile !== 'undefined') renderWidget();
    else window.addEventListener('load', renderWidget);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!turnstileToken) {
        status.textContent = 'Please complete the verification above.';
        status.className = 'text-sm rounded-lg px-4 py-3 bg-amber-50 text-amber-700 border border-amber-200';
        return;
      }

      const fd = new FormData(form);
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      status.className = 'hidden';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: fd.get('name'),
            email: fd.get('email'),
            company: fd.get('company'),
            message: fd.get('message'),
            'cf-turnstile-response': turnstileToken,
          }),
        });

        if (!res.ok) throw new Error();

        status.textContent = 'Message sent! We\u2019ll get back to you within 24 hours.';
        status.className = 'text-sm rounded-lg px-4 py-3 bg-green-50 text-green-700 border border-green-200';
        form.reset();
        turnstileToken = '';
        if (widgetId !== undefined) turnstile.reset(widgetId);
      } catch {
        status.textContent = 'Something went wrong. Please try again or email us directly.';
        status.className = 'text-sm rounded-lg px-4 py-3 bg-red-50 text-red-700 border border-red-200';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send message';
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
