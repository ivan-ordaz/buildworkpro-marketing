---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Blog - BuildWorkPro" description="Insights, tips, and updates for subcontractors running their business with BuildWorkPro.">
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Blog</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
          Insights for specialty contractors
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Tips on bidding, project management, billing, and growing your sub business.
        </p>
      </div>

      <div class="text-center py-20">
        <div class="inline-flex p-4 rounded-full bg-slate-100 mb-6">
          <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-900 mb-2">Coming soon</h2>
        <p class="text-slate-500 max-w-md mx-auto">
          We're working on articles about pay app best practices, bidding strategies, and field documentation tips. Check back soon.
        </p>
      </div>

    </div>
  </main>
  <Footer />
</Layout>
