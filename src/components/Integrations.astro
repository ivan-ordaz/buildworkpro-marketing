---
const integrations = [
  {
    name: 'Gmail',
    description: 'Send quotes and communicate with clients directly from BuildWorkPro.',
  },
  {
    name: 'Google Calendar',
    description: 'Sync project deadlines, inspections, and meetings to your calendar.',
  },
  {
    name: 'Claude',
    description: 'Connect Claude Desktop to BuildWorkPro and ask AI to draft bids, summarize projects, and more.',
  },
  {
    name: 'ChatGPT',
    description: 'Use ChatGPT with the BuildWorkPro MCP server to query your data and act on your behalf.',
  },
  /* TODO: Restore QuickBooks integration at launch
  {
    name: 'QuickBooks',
    description: 'Sync invoices, payments, and job costs with your accounting software.',
  },
  */
];
---

<section id="integrations" class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">
        Integrations
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-900 tracking-tight">
        Works with the tools you already use
      </h2>
      <p class="mt-4 text-lg text-slate-500 max-w-2xl mx-auto">
        Connect your existing workflow. BuildWorkPro plugs into Google Workspace and the AI assistants your team already relies on.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      {integrations.map((integration) => (
        <div class="text-center p-8 rounded-2xl border border-slate-100 hover:border-slate-200 bg-white hover:shadow-lg transition-all duration-300">
          <div class="inline-flex p-3 rounded-2xl bg-slate-50 mb-5">
            {integration.name === 'Gmail' && (
              <svg class="w-10 h-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z" fill="#EA4335"/>
              </svg>
            )}
            {integration.name === 'Google Calendar' && (
              <svg class="w-10 h-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.316 5.684H24v12.632h-5.684V5.684z" fill="#1A73E8"/>
                <path d="M5.684 24h12.632v-5.684H5.684V24z" fill="#1A73E8"/>
                <path d="M18.316 5.684V0H5.684v5.684h12.632z" fill="#EA4335"/>
                <path d="M5.684 18.316H0V5.684h5.684v12.632z" fill="#34A853"/>
                <path d="M18.316 24V18.316H24V24h-5.684z" fill="#188038"/>
                <path d="M5.684 5.684H0V0h5.684v5.684z" fill="#FBBC04"/>
                <path d="M18.316 0v5.684H24V0h-5.684z" fill="#4285F4"/>
                <path d="M5.684 24v-5.684H0V24h5.684z" fill="#0D652D"/>
                <path d="M8.572 16.2a3.34 3.34 0 0 1-1.236-1.092l1.104-.756c.24.384.528.672.864.876.336.204.72.3 1.14.3.432 0 .804-.108 1.116-.324.312-.216.468-.504.468-.864 0-.372-.168-.66-.504-.876-.336-.216-.756-.324-1.26-.324h-.78v-1.2h.696c.432 0 .792-.096 1.08-.288.288-.192.432-.468.432-.816 0-.312-.132-.564-.396-.756-.264-.192-.6-.288-1.008-.288-.396 0-.72.096-.972.288a2.2 2.2 0 0 0-.612.732l-1.092-.756c.228-.432.564-.792 1.008-1.08.444-.288 1.008-.432 1.692-.432.48 0 .912.084 1.296.252.384.168.684.396.9.696.216.3.324.636.324 1.02 0 .396-.1.732-.3 1.008-.2.276-.46.492-.78.648v.072c.384.168.696.408.936.72.24.312.36.684.36 1.116 0 .432-.12.816-.36 1.152-.24.336-.576.6-1.008.792-.432.192-.924.288-1.476.288-.648 0-1.236-.156-1.728-.456zM15.144 8.028l-1.212.924-.66-1.008 2.16-1.56h.924v9.504h-1.212V8.028z" fill="#4285F4"/>
              </svg>
            )}
            {integration.name === 'Claude' && (
              <svg class="w-10 h-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Claude">
                <path d="M4.709 15.955l4.72-2.647.079-.23-.079-.128h-.23l-.79-.048-2.695-.073-2.337-.097-2.265-.122-.571-.121L0 11.785l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.689-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.146-.103.018-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 0 1-.104-.729L6.276.169 6.69 0l1 .133.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z" fill="#D97757"/>
              </svg>
            )}
            {integration.name === 'ChatGPT' && (
              <svg class="w-10 h-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="ChatGPT">
                <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z" fill="currentColor"/>
              </svg>
            )}
            {/* TODO: Restore QuickBooks SVG at launch */}
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{integration.name}</h3>
          <p class="text-sm text-slate-500">{integration.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
