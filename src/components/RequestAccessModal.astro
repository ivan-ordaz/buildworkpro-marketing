---
---

<!-- Request Access Modal -->
<div id="request-access-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="request-access-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal Card -->
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div id="request-access-card" class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <!-- Close Button -->
      <button id="request-access-close" class="absolute top-4 right-4 p-1 text-slate-400 hover:text-slate-600 transition-colors" aria-label="Close">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Form View -->
      <div id="request-access-form-view" class="p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Request Early Access</h2>
        <p class="text-sm text-slate-500 mb-6">
          We're onboarding select contractors during our pre-launch phase. Tell us about your business and we'll be in touch.
        </p>

        <form id="request-access-form" class="space-y-4">
          <div>
            <label for="ra-name" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
            <input
              type="text"
              id="ra-name"
              name="name"
              required
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="John Smith"
            />
          </div>

          <div>
            <label for="ra-email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
            <input
              type="email"
              id="ra-email"
              name="email"
              required
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="john@example.com"
            />
          </div>

          <div>
            <label for="ra-company" class="block text-sm font-medium text-slate-700 mb-1">Company Name</label>
            <input
              type="text"
              id="ra-company"
              name="company"
              required
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="Smith Electric LLC"
            />
          </div>

          <div>
            <label for="ra-trade" class="block text-sm font-medium text-slate-700 mb-1">Trade / Specialty</label>
            <input
              type="text"
              id="ra-trade"
              name="trade"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="e.g., Glass & Glazing, HVAC, Electrical"
            />
          </div>

          <div>
            <label for="ra-message" class="block text-sm font-medium text-slate-700 mb-1">Message <span class="text-slate-400 font-normal">(optional)</span></label>
            <textarea
              id="ra-message"
              name="message"
              rows="3"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors resize-none"
              placeholder="Tell us about your business..."
            ></textarea>
          </div>

          <div id="request-access-error" class="hidden text-sm rounded-lg px-4 py-3 bg-red-50 text-red-700 border border-red-200"></div>

          <button
            type="submit"
            id="request-access-submit"
            class="w-full inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
          >
            Request Access
          </button>
        </form>
      </div>

      <!-- Success View -->
      <div id="request-access-success-view" class="p-8 text-center hidden">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-50 mb-4">
          <svg class="w-8 h-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Thank you!</h2>
        <p class="text-sm text-slate-500 mb-6">We'll be in touch shortly.</p>
        <button
          id="request-access-done"
          class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors"
        >
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function initRequestAccessModal() {
    const modal = document.getElementById('request-access-modal');
    const backdrop = document.getElementById('request-access-backdrop');
    const closeBtn = document.getElementById('request-access-close');
    const doneBtn = document.getElementById('request-access-done');
    const form = document.getElementById('request-access-form') as HTMLFormElement | null;
    const formView = document.getElementById('request-access-form-view');
    const successView = document.getElementById('request-access-success-view');

    if (!modal || !backdrop || !closeBtn || !form || !formView || !successView) return;

    function openModal() {
      modal!.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal!.classList.add('hidden');
      document.body.style.overflow = '';
      // Reset to form view after a short delay
      setTimeout(() => {
        formView!.classList.remove('hidden');
        successView!.classList.add('hidden');
        form!.reset();
      }, 300);
    }

    // Trigger buttons
    document.querySelectorAll('[data-request-access]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
    });

    // Close handlers
    backdrop.addEventListener('click', closeModal);
    closeBtn.addEventListener('click', closeModal);
    if (doneBtn) doneBtn.addEventListener('click', closeModal);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    // Prevent clicks inside the card from closing
    const card = document.getElementById('request-access-card');
    if (card) {
      card.addEventListener('click', (e) => e.stopPropagation());
    }

    // Form submission
    const submitBtn = document.getElementById('request-access-submit') as HTMLButtonElement | null;
    const errorEl = document.getElementById('request-access-error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }
      if (errorEl) errorEl.className = 'hidden';

      try {
        const res = await fetch('/api/request-access', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: formData.get('name'),
            email: formData.get('email'),
            company: formData.get('company'),
            trade: formData.get('trade'),
            message: formData.get('message'),
          }),
        });

        if (!res.ok) throw new Error();

        formView!.classList.add('hidden');
        successView!.classList.remove('hidden');
      } catch {
        if (errorEl) {
          errorEl.textContent = 'Something went wrong. Please try again.';
          errorEl.className = 'text-sm rounded-lg px-4 py-3 bg-red-50 text-red-700 border border-red-200';
        }
      } finally {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Request Access'; }
      }
    });
  }

  // Initialize on page load and after Astro page transitions
  initRequestAccessModal();
  document.addEventListener('astro:page-load', initRequestAccessModal);
</script>
