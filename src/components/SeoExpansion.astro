const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const expansion = expansions[currentPath];
---

{
  expansion && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="border-y border-slate-200 py-14">
        <div class="max-w-3xl mx-auto text-center mb-10">
          <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">
            {expansion.eyebrow}
          </p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">
            {expansion.title}
          </h2>
          <p class="mt-4 text-slate-500 leading-relaxed">{expansion.summary}</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {expansion.columns.map((column) => (
            <div>
              <h3 class="text-base font-semibold text-slate-900 mb-4">{column.title}</h3>
              <ul class="space-y-3">
                {column.items.map((item) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-slate-600">
                    <span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-500 shrink-0" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="mt-12 max-w-3xl mx-auto">
          <h3 class="text-xl font-bold text-slate-900 mb-6">Common questions</h3>
          <div class="space-y-3">
            {expansion.faqs.map((faq) => (
              <details class="border border-slate-200 rounded-xl overflow-hidden">
                <summary class="cursor-pointer px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50">
                  {faq.question}
                </summary>
                <p class="px-5 pb-4 text-sm leading-relaxed text-slate-600">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </div>

      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: expansion.faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: faq.answer,
            },
          })),
        })}
      />
    </section>
  )
}
