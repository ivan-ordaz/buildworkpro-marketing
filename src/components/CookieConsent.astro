---

---

<div
  id="cookie-consent"
  class="fixed bottom-4 left-1/2 -translate-x-1/2 z-40 hidden max-w-xl w-[calc(100%-2rem)]"
>
  <div
    class="flex items-center gap-3 px-4 py-2.5 rounded-xl border border-slate-200 bg-white/90 backdrop-blur-sm shadow-sm text-sm text-slate-600"
  >
    <p class="flex-1">
      We use essential cookies to make BuildWorkPro work, and analytics cookies only after you
      accept.
      <a
        href="/cookies/"
        class="text-brand-600 hover:text-brand-700 underline underline-offset-2 ml-1"
        >Cookie Policy</a
      >
    </p>
    <button
      id="cookie-decline"
      class="shrink-0 px-3 py-1 rounded-md border border-slate-300 text-slate-700 text-xs font-medium hover:bg-slate-50 transition-colors cursor-pointer"
    >
      Decline
    </button>
    <button
      id="cookie-accept"
      class="shrink-0 px-3 py-1 rounded-md bg-brand-600 text-white text-xs font-medium hover:bg-brand-700 transition-colors cursor-pointer"
    >
      Accept
    </button>
  </div>
</div>

<script>
  (function () {
    type CookieConsentWindow = Window & {
      bwpGrantAnalyticsConsent?: () => void;
      bwpLoadGA?: () => void;
      bwpRevokeAnalyticsConsent?: () => void;
      bwpOpenCookieSettings?: () => void;
    };

    const cookieWindow = window as CookieConsentWindow;
    const banner = document.getElementById('cookie-consent');
    if (!banner) return;

    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      localStorage.setItem('bwp-cookies-accepted', '1');
      localStorage.removeItem('bwp-cookies-declined');
      banner.classList.add('hidden');
      // Flip Consent Mode v2 signals BEFORE loading the analytics script, so
      // the very first pings carry granted consent rather than denied.
      cookieWindow.bwpGrantAnalyticsConsent?.();
      cookieWindow.bwpLoadGA?.();
    });
    document.getElementById('cookie-decline')?.addEventListener('click', () => {
      localStorage.setItem('bwp-cookies-declined', '1');
      localStorage.removeItem('bwp-cookies-accepted');
      banner.classList.add('hidden');
      cookieWindow.bwpRevokeAnalyticsConsent?.();
    });

    // Expose a reopen hook so the "Cookie settings" footer link can let
    // visitors change their choice after the banner was dismissed.
    cookieWindow.bwpOpenCookieSettings = () => banner.classList.remove('hidden');

    // Auto-show on first visit, before any choice has been recorded.
    if (
      !localStorage.getItem('bwp-cookies-accepted') &&
      !localStorage.getItem('bwp-cookies-declined')
    ) {
      banner.classList.remove('hidden');
    }
  })();
</script>
