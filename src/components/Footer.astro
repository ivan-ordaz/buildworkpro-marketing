---
const footerLinks = {
  Product: [
    { label: 'Features', href: '#features' },
    { label: 'Pricing', href: '#pricing' },
    { label: 'Integrations', href: '#integrations' },
    { label: 'FAQ', href: '#faq' },
  ],
  Company: [
    { label: 'About', href: '#' },
    { label: 'Blog', href: '#' },
    { label: 'Careers', href: '#' },
    { label: 'Contact', href: '#' },
  ],
  Legal: [
    { label: 'Privacy', href: '#' },
    { label: 'Terms', href: '#' },
    { label: 'Security', href: '#' },
  ],
};
---

<footer class="bg-slate-900 text-slate-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2">
        <a href="/" class="flex items-center mb-4">
          <img
            src="/logo.png"
            alt="BuildWorkPro"
            class="h-9 w-auto brightness-0 invert"
          />
        </a>
        <p class="text-sm text-slate-400 max-w-xs leading-relaxed">
          The all-in-one construction project management and ERP platform for modern contractors.
        </p>
      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h4 class="text-sm font-semibold text-white mb-4">{category}</h4>
          <ul class="space-y-3">
            {links.map((link) => (
              <li>
                <a href={link.href} class="text-sm hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm">&copy; {new Date().getFullYear()} BuildWorkPro. All rights reserved.</p>
    </div>
  </div>
</footer>
