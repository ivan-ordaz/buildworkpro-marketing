---
---

<section class="py-24 lg:py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Feature 1: Dashboard -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center mb-32">
      <div>
        <div class="inline-flex items-center gap-2 bg-brand-50 text-brand-700 px-3 py-1 rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
          </svg>
          Dashboard & Analytics
        </div>
        <h3 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
          See your business at a glance
        </h3>
        <p class="text-lg text-slate-500 mb-8 leading-relaxed">
          Real-time KPIs, project statuses, revenue trends, and team activity. Your entire operation distilled into actionable insights.
        </p>
        <ul class="space-y-4">
          {[
            'Real-time project and revenue dashboards',
            'Activity feeds with team-wide visibility',
            'Exportable reports and analytics',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-white rounded-2xl shadow-xl border border-slate-200/80 p-6">
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div class="bg-brand-50 rounded-xl p-4">
            <div class="text-sm text-brand-600 font-medium">Revenue</div>
            <div class="text-3xl font-bold text-slate-900 mt-1">$1.2M</div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 11l5-5m0 0l5 5m-5-5v12" /></svg>
              <span class="text-sm text-emerald-600 font-medium">+8.2%</span>
            </div>
          </div>
          <div class="bg-emerald-50 rounded-xl p-4">
            <div class="text-sm text-emerald-600 font-medium">Projects Won</div>
            <div class="text-3xl font-bold text-slate-900 mt-1">47</div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 11l5-5m0 0l5 5m-5-5v12" /></svg>
              <span class="text-sm text-emerald-600 font-medium">+12%</span>
            </div>
          </div>
        </div>
        <div class="bg-slate-50 rounded-xl p-4 h-40 flex items-end gap-1.5">
          {[35, 50, 42, 65, 55, 70, 60, 80, 72, 88, 78, 92].map((h) => (
            <div class="flex-1 bg-brand-500 rounded-t transition-all" style={`height: ${h}%`}></div>
          ))}
        </div>
      </div>
    </div>

    <!-- Feature 2: Quotes -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center mb-32">
      <div class="order-2 lg:order-1 bg-white rounded-2xl shadow-xl border border-slate-200/80 p-6">
        <div class="flex items-center justify-between mb-6">
          <div>
            <div class="text-sm text-slate-500">Quote #1042</div>
            <div class="text-lg font-semibold text-slate-900">Kitchen Renovation - Williams</div>
          </div>
          <span class="px-3 py-1 text-xs font-medium bg-amber-50 text-amber-700 rounded-full">Draft</span>
        </div>
        <div class="space-y-3 mb-6">
          {[
            { item: 'Demolition & Disposal', qty: '1', price: '$2,800' },
            { item: 'Custom Cabinetry', qty: '12', price: '$18,400' },
            { item: 'Countertop Installation', qty: '1', price: '$6,200' },
            { item: 'Electrical Rough-in', qty: '1', price: '$3,100' },
            { item: 'Plumbing Fixtures', qty: '4', price: '$4,500' },
          ].map((line) => (
            <div class="flex items-center justify-between py-2 border-b border-slate-100 last:border-0">
              <div class="text-sm text-slate-700">{line.item}</div>
              <div class="text-sm font-medium text-slate-900">{line.price}</div>
            </div>
          ))}
        </div>
        <div class="flex items-center justify-between pt-4 border-t-2 border-slate-200">
          <span class="text-sm font-semibold text-slate-900">Total</span>
          <span class="text-xl font-bold text-slate-900">$35,000</span>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <div class="inline-flex items-center gap-2 bg-violet-50 text-violet-700 px-3 py-1 rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" />
          </svg>
          Professional Quotes
        </div>
        <h3 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
          Win more bids, faster
        </h3>
        <p class="text-lg text-slate-500 mb-8 leading-relaxed">
          Create polished estimates with line items, templates, and distributed costs. Generate PDFs and send them directly to clients.
        </p>
        <ul class="space-y-4">
          {[
            'Reusable templates and product catalog',
            'One-click PDF generation and email sending',
            'Automatic expiry tracking and follow-ups',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-violet-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Feature 3: Real-time -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <div class="inline-flex items-center gap-2 bg-emerald-50 text-emerald-700 px-3 py-1 rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Real-Time Collaboration
        </div>
        <h3 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
          Keep your whole crew in sync
        </h3>
        <p class="text-lg text-slate-500 mb-8 leading-relaxed">
          Live notifications, activity tracking, and team-wide visibility. Everyone sees updates the moment they happen.
        </p>
        <ul class="space-y-4">
          {[
            'Live notifications across all devices',
            'Complete audit trail and activity history',
            'Commenting and collaboration on any item',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-emerald-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-white rounded-2xl shadow-xl border border-slate-200/80 p-6">
        <div class="text-sm font-semibold text-slate-900 mb-4">Live Activity Feed</div>
        <div class="space-y-4">
          {[
            { user: 'M.R.', action: 'completed task', detail: 'Foundation pour - Phase 2', time: '2m ago', color: 'bg-emerald-500' },
            { user: 'S.L.', action: 'added comment on', detail: 'Riverside Apartments', time: '5m ago', color: 'bg-brand-500' },
            { user: 'J.K.', action: 'sent quote to', detail: 'Williams Residence', time: '12m ago', color: 'bg-violet-500' },
            { user: 'A.P.', action: 'updated lead stage', detail: 'Oak Street Office', time: '18m ago', color: 'bg-amber-500' },
            { user: 'D.M.', action: 'uploaded document', detail: 'Permit_Rev3.pdf', time: '25m ago', color: 'bg-cyan-500' },
          ].map((item) => (
            <div class="flex items-start gap-3">
              <div class={`w-8 h-8 ${item.color} rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0`}>
                {item.user}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-slate-700">
                  <span class="font-medium">{item.user}</span> {item.action} <span class="font-medium text-slate-900">{item.detail}</span>
                </p>
                <p class="text-xs text-slate-400 mt-0.5">{item.time}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
