---
const sections = [
  {
    badge: 'Dashboard & Analytics',
    badgeColor: 'brand',
    heading: 'See your business at a glance',
    description: 'Real-time KPIs, project statuses, revenue trends, and team activity. Your entire operation distilled into actionable insights.',
    bullets: [
      'Real-time project, revenue, and pipeline KPIs',
      'Activity feeds with team-wide visibility',
      'Pipeline tracking and project status overview',
    ],
    image: '/screenshots/01-dashboard.png',
    imageAlt: 'BuildWorkPro dashboard with KPIs showing active projects, pipeline value, and revenue metrics',
    layout: 'text-left',
  },
  {
    badge: 'Sales Pipeline',
    badgeColor: 'emerald',
    heading: 'Track every deal from lead to close',
    description: 'Visual Kanban board with drag-and-drop stages. See your entire pipeline at a glance and never let a deal slip through the cracks.',
    bullets: [
      'Kanban board with drag-and-drop lead stages',
      'Deal values and probability tracking',
      'Stage-based pipeline with conversion analytics',
    ],
    image: '/screenshots/02-pipeline-kanban.png',
    imageAlt: 'Sales pipeline Kanban board showing leads organized by stage with deal values',
    layout: 'image-left',
  },
  {
    badge: 'Professional Bids & Estimates',
    badgeColor: 'violet',
    heading: 'Win more bids, faster',
    description: 'Create detailed bids with line items, cost breakdowns, and distributed costs. Generate polished PDFs and convert accepted bids directly into projects.',
    bullets: [
      'Detailed line items with cost breakdown sidebar',
      'One-click PDF generation and client delivery',
      'Bid-to-project conversion on acceptance',
    ],
    image: '/screenshots/05-bid-detail-overview.png',
    imageAlt: 'Accepted bid detail showing line items, cost breakdown sidebar, and bid summary',
    layout: 'text-left',
  },
  {
    badge: 'Project Management',
    badgeColor: 'brand',
    heading: 'From groundbreaking to punch list',
    description: 'Plan and track every phase of your project with Gantt charts, task dependencies, and team assignments. Keep everyone aligned from start to finish.',
    bullets: [
      'Phases and tasks with Gantt chart visualization',
      'Team assignment and workload tracking',
      'Progress tracking with milestone dependencies',
    ],
    image: '/screenshots/17-project-gantt.png',
    imageAlt: 'Project Gantt chart showing phases, tasks, and timeline with dependencies',
    layout: 'image-left',
  },
  {
    badge: 'Pay Applications',
    badgeColor: 'rose',
    heading: 'Get paid on time, every time',
    description: 'Construction-specific pay applications in AIA G702/G703 format with built-in approval workflows. Track progress billing, retainage, and change orders in one place.',
    bullets: [
      'AIA G702/G703 format pay applications',
      'Workflow approval: Draft, Submitted, Approved, Paid',
      'Retainage tracking and schedule of values',
    ],
    image: '/screenshots/13-pay-app-detail.png',
    imageAlt: 'Pay application detail showing workflow stepper, AIA summary, and schedule of values',
    layout: 'text-left',
  },
  {
    badge: 'Change Orders',
    badgeColor: 'amber',
    heading: 'Manage scope changes with confidence',
    description: 'Track every scope change with a structured approval workflow. See the real-time impact on your contract value and keep all stakeholders aligned.',
    bullets: [
      'Multi-step workflow approval stepper',
      'Real-time contract impact tracking',
      'PDF generation for client and GC sign-off',
    ],
    image: '/screenshots/09-change-order-detail.png',
    imageAlt: 'Change order detail showing workflow stepper, line items, and contract impact',
    layout: 'image-left',
  },
  {
    badge: 'Site Logs',
    badgeColor: 'cyan',
    heading: 'Document the field, every day',
    description: 'Daily field reports with weather conditions, personnel counts, equipment usage, and work performed. Build an airtight record of every jobsite day.',
    bullets: [
      'Daily field reports with structured data entry',
      'Weather conditions and personnel tracking',
      'Photo documentation and crew logs',
    ],
    image: '/screenshots/11-site-log-detail.png',
    imageAlt: 'Site log detail showing weather data, personnel list, and daily work summary',
    layout: 'text-left',
  },
  {
    badge: 'Reports & Analytics',
    badgeColor: 'emerald',
    heading: 'Data-driven decisions for your business',
    description: 'Comprehensive reports with visual charts for pipeline health, bid analytics, project tracking, and financial performance. Export anything to CSV.',
    bullets: [
      'Pipeline and bid analytics with visual charts',
      'Project tracking and financial reports',
      'One-click export to CSV for any dataset',
    ],
    image: '/screenshots/19-reports.png',
    imageAlt: 'Reports dashboard showing bar charts and donut charts for pipeline and project analytics',
    layout: 'image-left',
  },
];

const badgeColorMap: Record<string, { bg: string; text: string; check: string }> = {
  brand: { bg: 'bg-brand-50', text: 'text-brand-700', check: 'text-brand-600' },
  emerald: { bg: 'bg-emerald-50', text: 'text-emerald-700', check: 'text-emerald-600' },
  violet: { bg: 'bg-violet-50', text: 'text-violet-700', check: 'text-violet-600' },
  amber: { bg: 'bg-amber-50', text: 'text-amber-700', check: 'text-amber-600' },
  rose: { bg: 'bg-rose-50', text: 'text-rose-700', check: 'text-rose-600' },
  cyan: { bg: 'bg-cyan-50', text: 'text-cyan-700', check: 'text-cyan-600' },
};
---

<section class="py-24 lg:py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {sections.map((section, index) => {
      const colors = badgeColorMap[section.badgeColor];
      const isImageLeft = section.layout === 'image-left';
      const isLast = index === sections.length - 1;

      return (
        <div class={`grid lg:grid-cols-2 gap-12 lg:gap-20 items-center ${isLast ? '' : 'mb-28 lg:mb-36'}`}>
          {/* Text content */}
          <div class={isImageLeft ? 'order-2 lg:order-2' : ''}>
            <div class={`inline-flex items-center gap-2 ${colors.bg} ${colors.text} px-3 py-1 rounded-full text-sm font-medium mb-6`}>
              {section.badge}
            </div>
            <h3 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
              {section.heading}
            </h3>
            <p class="text-lg text-slate-500 mb-8 leading-relaxed">
              {section.description}
            </p>
            <ul class="space-y-4">
              {section.bullets.map((item) => (
                <li class="flex items-start gap-3">
                  <svg class={`w-5 h-5 ${colors.check} mt-0.5 shrink-0`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-slate-600">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          {/* Screenshot */}
          <div class={isImageLeft ? 'order-1 lg:order-1' : ''}>
            <div class="rounded-2xl border border-slate-200/80 shadow-xl overflow-hidden bg-white">
              <img
                src={section.image}
                alt={section.imageAlt}
                class="w-full h-auto block"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      );
    })}

  </div>
</section>
