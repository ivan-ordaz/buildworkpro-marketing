---
---

<section class="py-16 border-y border-slate-100 bg-slate-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium text-slate-400 uppercase tracking-wider mb-8">
      Built for every trade
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-y-5 gap-x-6 max-w-4xl mx-auto">
      {[
        { icon: 'M3 21h18M3 21V7l9-4 9 4v14', label: 'Roofing' },
        { icon: 'M3 3h18v18H3zM9 3v18M15 3v18M3 9h18M3 15h18', label: 'Glass & Glazing' },
        { icon: 'M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z', label: 'HVAC' },
        { icon: 'M4 21v-4a4 4 0 014-4h0a4 4 0 014 4v4M12 13V3m0 0L9 6m3-3l3 3M16 21v-2a4 4 0 00-4-4', label: 'Plumbing' },
        { icon: 'M13 10V3L4 14h7v7l9-11h-7z', label: 'Electrical' },
        { icon: 'M12 3c4.97 0 9 4.03 9 9s-4.03 9-9 9-9-4.03-9-9 4.03-9 9-9zM9 12a3 3 0 106 0 3 3 0 00-6 0z', label: 'Pool & Spa' },
        { icon: 'M4 21h16M4 21V10l4-4h8l4 4v11M8 21v-6h8v6M12 6V3', label: 'Concrete & Masonry' },
        { icon: 'M4 21l16-16M4 11l10-10M14 21L20 15M10 21l4-4', label: 'Framing' },
        { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', label: 'Painting' },
        { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', label: 'Remodeling' },
      ].map((item) => (
        <div class="flex items-center justify-center gap-2 text-slate-400">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span class="text-sm font-medium whitespace-nowrap">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
