---
const features = [
  { label: 'Bidding & Estimating', href: '/features/construction-bidding/' },
  { label: 'Pay Applications', href: '/features/pay-applications/' },
  { label: 'Change Orders', href: '/features/change-orders/' },
  { label: 'Project Management', href: '/features/project-management/' },
  { label: 'Site Logs', href: '/features/site-logs/' },
  { label: 'Time Tracking', href: '/features/time-tracking/' },
  { label: 'CRM & Pipeline', href: '/features/construction-crm/' },
  { label: 'Reports & Analytics', href: '/features/reports/' },
];

const solutions = [
  { label: 'HVAC Contractors', href: '/solutions/hvac-contractors/' },
  { label: 'Electrical Contractors', href: '/solutions/electrical-contractors/' },
  { label: 'Plumbing Contractors', href: '/solutions/plumbing-contractors/' },
  { label: 'Concrete Contractors', href: '/solutions/concrete-contractors/' },
  { label: 'Roofing Contractors', href: '/solutions/roofing-contractors/' },
  { label: 'Framing Contractors', href: '/solutions/framing-contractors/' },
];

const compare = [
  { label: 'vs Procore', href: '/compare/procore-alternative/' },
  { label: 'vs Buildertrend', href: '/compare/buildertrend-alternative/' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center group">
        <img src="/logo.png" alt="BuildWorkPro" class="h-11 lg:h-12 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="Primary">
        <!-- Features dropdown -->
        <div class="relative group/menu">
          <button
            type="button"
            class="flex items-center gap-1 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors py-2"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Features
            <svg
              class="w-4 h-4 transition-transform group-hover/menu:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible focus-within:opacity-100 focus-within:visible transition-all duration-150 z-50"
          >
            <div
              class="w-64 bg-white border border-slate-100 rounded-xl shadow-xl py-2"
              role="menu"
            >
              {
                features.map((item) => (
                  <a
                    href={item.href}
                    class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-brand-600 transition-colors"
                    role="menuitem"
                  >
                    {item.label}
                  </a>
                ))
              }
              <div class="border-t border-slate-100 mt-2 pt-2">
                <a
                  href="/features/"
                  class="flex items-center justify-between px-4 py-2 text-sm font-semibold text-brand-600 hover:bg-brand-50 transition-colors"
                  role="menuitem"
                >
                  View all features
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Solutions dropdown -->
        <div class="relative group/menu">
          <button
            type="button"
            class="flex items-center gap-1 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors py-2"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Solutions
            <svg
              class="w-4 h-4 transition-transform group-hover/menu:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible focus-within:opacity-100 focus-within:visible transition-all duration-150 z-50"
          >
            <div
              class="w-64 bg-white border border-slate-100 rounded-xl shadow-xl py-2"
              role="menu"
            >
              {
                solutions.map((item) => (
                  <a
                    href={item.href}
                    class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-brand-600 transition-colors"
                    role="menuitem"
                  >
                    {item.label}
                  </a>
                ))
              }
              <div class="border-t border-slate-100 mt-2 pt-2">
                <a
                  href="/solutions/"
                  class="flex items-center justify-between px-4 py-2 text-sm font-semibold text-brand-600 hover:bg-brand-50 transition-colors"
                  role="menuitem"
                >
                  View all solutions
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Compare dropdown -->
        <div class="relative group/menu">
          <button
            type="button"
            class="flex items-center gap-1 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors py-2"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Compare
            <svg
              class="w-4 h-4 transition-transform group-hover/menu:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible focus-within:opacity-100 focus-within:visible transition-all duration-150 z-50"
          >
            <div
              class="w-56 bg-white border border-slate-100 rounded-xl shadow-xl py-2"
              role="menu"
            >
              {
                compare.map((item) => (
                  <a
                    href={item.href}
                    class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-brand-600 transition-colors"
                    role="menuitem"
                  >
                    {item.label}
                  </a>
                ))
              }
              <div class="border-t border-slate-100 mt-2 pt-2">
                <a
                  href="/compare/"
                  class="flex items-center justify-between px-4 py-2 text-sm font-semibold text-brand-600 hover:bg-brand-50 transition-colors"
                  role="menuitem"
                >
                  All comparisons
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <a
          href="/#pricing"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >
          Pricing
        </a>
        <a
          href="/docs/"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >
          Docs
        </a>
        <a
          href="/api/"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >
          API
        </a>
        <a
          href="/blog/"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >
          Blog
        </a>
      </nav>

      <!-- CTA Buttons -->
      <!-- TODO: Restore "Log in" link and "Start free trial" button at launch -->
      <div class="hidden md:flex items-center gap-3">
        <button
          data-request-access
          class="text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 px-5 py-2.5 rounded-lg cursor-pointer transition-all hover:-translate-y-0.5"
        >
          Request Access
        </button>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-slate-600 hover:text-slate-900"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            id="menu-icon"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-slate-100 shadow-lg max-h-[calc(100vh-4rem)] overflow-y-auto"
  >
    <div class="px-4 py-4 space-y-1">
      <!-- Features accordion -->
      <details class="group">
        <summary
          class="flex items-center justify-between text-sm font-medium text-slate-700 py-3 cursor-pointer list-none"
        >
          <span>Features</span>
          <svg
            class="w-4 h-4 transition-transform group-open:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </summary>
        <div class="pl-3 pb-2 space-y-1">
          {
            features.map((item) => (
              <a href={item.href} class="block py-2 text-sm text-slate-600 hover:text-brand-600">
                {item.label}
              </a>
            ))
          }
          <a
            href="/features/"
            class="block py-2 text-sm font-semibold text-brand-600 hover:text-brand-700"
          >
            View all features →
          </a>
        </div>
      </details>

      <!-- Solutions accordion -->
      <details class="group">
        <summary
          class="flex items-center justify-between text-sm font-medium text-slate-700 py-3 cursor-pointer list-none"
        >
          <span>Solutions</span>
          <svg
            class="w-4 h-4 transition-transform group-open:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </summary>
        <div class="pl-3 pb-2 space-y-1">
          {
            solutions.map((item) => (
              <a href={item.href} class="block py-2 text-sm text-slate-600 hover:text-brand-600">
                {item.label}
              </a>
            ))
          }
          <a
            href="/solutions/"
            class="block py-2 text-sm font-semibold text-brand-600 hover:text-brand-700"
          >
            View all solutions →
          </a>
        </div>
      </details>

      <!-- Compare accordion -->
      <details class="group">
        <summary
          class="flex items-center justify-between text-sm font-medium text-slate-700 py-3 cursor-pointer list-none"
        >
          <span>Compare</span>
          <svg
            class="w-4 h-4 transition-transform group-open:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </summary>
        <div class="pl-3 pb-2 space-y-1">
          {
            compare.map((item) => (
              <a href={item.href} class="block py-2 text-sm text-slate-600 hover:text-brand-600">
                {item.label}
              </a>
            ))
          }
          <a
            href="/compare/"
            class="block py-2 text-sm font-semibold text-brand-600 hover:text-brand-700"
          >
            All comparisons →
          </a>
        </div>
      </details>

      <a
        href="/#pricing"
        class="block py-3 text-sm font-medium text-slate-700 hover:text-brand-600"
      >
        Pricing
      </a>
      <a href="/docs/" class="block py-3 text-sm font-medium text-slate-700 hover:text-brand-600">
        Docs
      </a>
      <a href="/api/" class="block py-3 text-sm font-medium text-slate-700 hover:text-brand-600">
        API
      </a>
      <a href="/blog/" class="block py-3 text-sm font-medium text-slate-700 hover:text-brand-600">
        Blog
      </a>

      <!-- TODO: Restore "Log in" link and "Start free trial" button at launch -->
      <div class="pt-3 border-t border-slate-100 space-y-2">
        <button
          data-request-access
          class="block w-full text-center text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 px-5 py-2.5 rounded-lg cursor-pointer transition-all"
        >
          Request Access
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const mobileMenuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // Sticky header background
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm');
    } else {
      header.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm');
    }
  });

  // Mobile menu toggle
  mobileMenuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.toggle('hidden');
    mobileMenuBtn.setAttribute('aria-expanded', String(isOpen));
  });

  // Close mobile menu on link click (but not on accordion summary clicks)
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
