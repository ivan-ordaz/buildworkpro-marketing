---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import { config } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'BuildWorkPro - Construction Project Management & ERP Platform',
  description = 'The all-in-one platform for construction companies. Manage projects, contacts, quotes, billing, and your entire team from a single, powerful dashboard.',
  image = '/og-image.png',
  noindex = false,
} = Astro.props;

const ogImageUrl = new URL(image, Astro.site).href;

// Auto-generate BreadcrumbList JSON-LD from the URL path so feature/solution/
// compare/blog pages become rich-result eligible. Home is always first; each
// path segment becomes a crumb labeled from a known map (falls back to a
// Title-Cased version of the slug).
const breadcrumbLabels: Record<string, string> = {
  features: 'Features',
  solutions: 'Solutions',
  compare: 'Compare',
  blog: 'Blog',
  docs: 'Docs',
  api: 'API',
  security: 'Security',
  disclosure: 'Responsible Disclosure',
  about: 'About',
  contact: 'Contact',
  support: 'Support',
  integrations: 'Integrations',
  developers: 'Developers',
  privacy: 'Privacy',
  terms: 'Terms',
  cookies: 'Cookies',
};

const segments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).href },
  ...segments.map((seg, i) => {
    const slug = seg.toLowerCase();
    const label =
      breadcrumbLabels[slug] ?? slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    const url = new URL(`/${segments.slice(0, i + 1).join('/')}/`, Astro.site).href;
    return { name: label, url };
  }),
];

const showBreadcrumbs = breadcrumbItems.length > 1;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Consent Mode v2. GA4 loads on EVERY page with consent
         default-denied, so it sends cookieless, anonymized pings (no cookies,
         no ad identifiers) for visitors who have not chosen yet. On Accept it
         upgrades to full measurement; on Decline it is fully disabled. The
         Meta Pixel has no cookieless mode, so it loads only on Accept. The
         consent default must run BEFORE the gtag.js loader so the first ping
         is scoped correctly. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      // CRITICAL: gtag must push the `arguments` object, exactly as in Google's
      // canonical snippet. gtag.js distinguishes an `arguments` object (a gtag
      // API command: consent/config/js/get) from a plain array (a generic
      // dataLayer event). A rest-param `(...args)` pushed as an array makes
      // gtag.js silently treat `consent`/`config` as events, so consent never
      // resolves and NO hit is ever sent — the property stays empty. Do NOT
      // "modernize" this to rest params (the eslint-disable below guards it).
      function gtag() {
        // eslint-disable-next-line prefer-rest-params
        window.dataLayer.push(arguments);
      }
      // Consent Mode v2 — default-deny. `wait_for_update` gives the
      // CookieConsent banner ~500ms to update consent before any pings fire,
      // avoiding a denied ping followed immediately by a granted one.
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'denied',
        personalization_storage: 'denied',
        security_storage: 'granted',
        wait_for_update: 500,
      });
      // Redact ad-click identifiers from requests while consent is denied, so
      // the default cookieless pings stay anonymous.
      gtag('set', 'ads_data_redaction', true);
      // Exposed so the CookieConsent component can flip consent on accept.
      window.bwpGrantAnalyticsConsent = function () {
        window['ga-disable-G-REK78NBR14'] = false;
        gtag('consent', 'update', {
          ad_storage: 'granted',
          ad_user_data: 'granted',
          ad_personalization: 'granted',
          analytics_storage: 'granted',
          functionality_storage: 'granted',
          personalization_storage: 'granted',
        });
      };
      // Called on explicit Decline (and via "Cookie settings"). A decline is a
      // real opt-out: fully disable GA so not even cookieless pings are sent.
      window.bwpRevokeAnalyticsConsent = function () {
        window['ga-disable-G-REK78NBR14'] = true;
        gtag('consent', 'update', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'denied',
          functionality_storage: 'denied',
          personalization_storage: 'denied',
        });
      };
      window.bwpLoadGA = function () {
        if (window.__bwpGALoaded) return;
        window.__bwpGALoaded = true;
        const s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-REK78NBR14';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-REK78NBR14');
      };
      // Meta Pixel (Facebook) — loaded only on Accept. It has no cookieless
      // mode, so unlike GA4 it does NOT load by default and never loads on
      // decline. Pixel ID is a public client-side identifier (like the GA id).
      window.bwpLoadMetaPixel = function () {
        if (window.__bwpPixelLoaded) return;
        window.__bwpPixelLoaded = true;
        const n = function (...args) {
          if (n.callMethod) {
            n.callMethod(...args);
          } else {
            n.queue.push(args);
          }
        };
        window.fbq = n;
        if (!window._fbq) window._fbq = n;
        n.push = n;
        n.loaded = true;
        n.version = '2.0';
        n.queue = [];
        const t = document.createElement('script');
        t.async = true;
        t.src = 'https://connect.facebook.net/en_US/fbevents.js';
        document.head.appendChild(t);
        window.fbq('init', '689268612776537');
        window.fbq('track', 'PageView');
      };
      // Unified conversion-event tracker. GA4 is always loaded (cookieless
      // until consent), so GA events flow for every visitor; Meta events fire
      // only once the pixel has loaded (i.e. after Accept). Never throws:
      // analytics must never break the page.
      window.bwpTrack = function (meta, ga) {
        try {
          if (meta && window.fbq) window.fbq('track', meta.name, meta.params || {});
          if (ga && window.__bwpGALoaded) gtag('event', ga.name, ga.params || {});
        } catch {
          /* best-effort — swallow */
        }
      };
      // Apply any stored choice, then load. Three postures:
      //  • Declined     → fully disable GA, load nothing.
      //  • Accepted     → grant consent + full GA + Meta Pixel.
      //  • No choice yet → GA loads cookieless (default-deny); no pixel.
      let bwpAccepted = false;
      let bwpDeclined = false;
      try {
        bwpAccepted = !!localStorage.getItem('bwp-cookies-accepted');
        bwpDeclined = !!localStorage.getItem('bwp-cookies-declined');
      } catch {
        /* localStorage unavailable (private browsing, SSR) — treat as no choice */
      }
      if (bwpDeclined) {
        window['ga-disable-G-REK78NBR14'] = true;
      } else {
        if (bwpAccepted) window.bwpGrantAnalyticsConsent();
        window.bwpLoadGA();
        if (bwpAccepted) window.bwpLoadMetaPixel();
      }
    </script>

    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={Astro.url.href} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="BuildWorkPro" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Organization Schema -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'BuildWorkPro',
        url: config.siteUrl,
        logo: `${config.siteUrl}/logo.png`,
        contactPoint: {
          '@type': 'ContactPoint',
          email: config.email.support,
          contactType: 'customer support',
        },
        sameAs: [],
      })}
    />

    <!-- BreadcrumbList Schema (skipped on the homepage). -->
    {
      showBreadcrumbs && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'BreadcrumbList',
            itemListElement: breadcrumbItems.map((item, i) => ({
              '@type': 'ListItem',
              position: i + 1,
              name: item.name,
              item: item.url,
            })),
          })}
        />
      )
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer
    ></script>
    <title>{title}</title>
  </head>
  <body class="bg-white text-slate-900 font-sans" data-turnstile-sitekey={config.turnstileSiteKey}>
    <slot />
    <CookieConsent />

    <!-- Conversion-event instrumentation (Meta Pixel + GA4). Runs on every
         page. GA4 events flow cookielessly for every visitor; Meta events fire
         only once the pixel loads on Accept (see bwpTrack in the head). -->
    <script is:inline define:vars={{ signupUrl: config.signupUrl }}>
      (function () {
        function track(meta, ga) {
          if (window.bwpTrack) window.bwpTrack(meta, ga);
        }

        // 1. Primary conversion: every "Start free trial" CTA points at
        //    config.signupUrl, so one delegated listener instruments all 40+
        //    of them. User-triggered, so it naturally post-dates consent.
        function onCtaActivate(e) {
          const a = e.target && e.target.closest && e.target.closest('a[href]');
          if (!a || a.href.indexOf(signupUrl) !== 0) return;
          track(
            {
              name: 'InitiateCheckout',
              params: { content_name: 'free_trial', content_category: 'signup' },
            },
            { name: 'start_trial', params: { cta_href: a.href } }
          );
        }
        document.addEventListener('click', onCtaActivate);
        document.addEventListener('auxclick', onCtaActivate); // middle-click → new tab

        // 2 & 3. High-intent page views, fired immediately on load. GA4
        //        captures them cookielessly for every visitor; Meta captures
        //        them only when the pixel is already loaded (returning accepters).
        (function () {
          // Feature detail pages (/features/<slug>/) — not the /features/ hub.
          const fm = location.pathname.match(/^\/features\/([^/]+)\/?$/);
          if (fm) {
            track(
              { name: 'ViewContent', params: { content_type: 'feature', content_name: fm[1] } },
              { name: 'view_feature', params: { feature: fm[1] } }
            );
          }

          // Pricing is a section (#pricing), not a route — fire once when it
          // first scrolls into view, a stronger intent signal than page load.
          const pricing = document.getElementById('pricing');
          if (pricing && 'IntersectionObserver' in window) {
            let fired = false;
            const io = new IntersectionObserver(
              function (entries) {
                for (let i = 0; i < entries.length; i++) {
                  if (entries[i].isIntersecting && !fired) {
                    fired = true;
                    io.disconnect();
                    track(
                      {
                        name: 'ViewContent',
                        params: { content_type: 'pricing', content_name: 'pricing' },
                      },
                      { name: 'view_pricing' }
                    );
                  }
                }
              },
              { threshold: 0.4 }
            );
            io.observe(pricing);
          }
        })();
      })();
    </script>
  </body>
</html>
