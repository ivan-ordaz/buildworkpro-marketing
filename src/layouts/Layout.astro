---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import { config } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'BuildWorkPro - Construction Project Management & ERP Platform',
  description = 'The all-in-one platform for construction companies. Manage projects, contacts, quotes, billing, and your entire team from a single, powerful dashboard.',
  image = '/og-image.png',
  noindex = false,
} = Astro.props;

const ogImageUrl = new URL(image, Astro.site).href;

// Auto-generate BreadcrumbList JSON-LD from the URL path so feature/solution/
// compare/blog pages become rich-result eligible. Home is always first; each
// path segment becomes a crumb labeled from a known map (falls back to a
// Title-Cased version of the slug).
const breadcrumbLabels: Record<string, string> = {
  features: 'Features',
  solutions: 'Solutions',
  compare: 'Compare',
  blog: 'Blog',
  docs: 'Docs',
  api: 'API',
  security: 'Security',
  disclosure: 'Responsible Disclosure',
  about: 'About',
  contact: 'Contact',
  support: 'Support',
  integrations: 'Integrations',
  developers: 'Developers',
  privacy: 'Privacy',
  terms: 'Terms',
  cookies: 'Cookies',
};

const segments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).href },
  ...segments.map((seg, i) => {
    const slug = seg.toLowerCase();
    const label =
      breadcrumbLabels[slug] ?? slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    const url = new URL(`/${segments.slice(0, i + 1).join('/')}/`, Astro.site).href;
    return { name: label, url };
  }),
];

const showBreadcrumbs = breadcrumbItems.length > 1;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Consent Mode v2 + gtag (loaded only after cookie consent).
         Default-deny every category until the user explicitly accepts in the
         CookieConsent banner. The default must run BEFORE the gtag.js loader
         so signals are scoped correctly from the very first GA call. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args) {
        window.dataLayer.push(args);
      }
      // Consent Mode v2 — default-deny. `wait_for_update` gives the
      // CookieConsent banner ~500ms to update consent before any pings fire,
      // avoiding a denied ping followed immediately by a granted one.
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'denied',
        personalization_storage: 'denied',
        security_storage: 'granted',
        wait_for_update: 500,
      });
      // Exposed so the CookieConsent component can flip consent on accept.
      window.bwpGrantAnalyticsConsent = function () {
        gtag('consent', 'update', {
          ad_storage: 'granted',
          ad_user_data: 'granted',
          ad_personalization: 'granted',
          analytics_storage: 'granted',
          functionality_storage: 'granted',
          personalization_storage: 'granted',
        });
      };
      window.bwpRevokeAnalyticsConsent = function () {
        gtag('consent', 'update', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'denied',
          functionality_storage: 'denied',
          personalization_storage: 'denied',
        });
      };
      window.bwpLoadGA = function () {
        if (window.__bwpGALoaded) return;
        window.__bwpGALoaded = true;
        const s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-REK78NBR14';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-REK78NBR14');
      };
      try {
        if (localStorage.getItem('bwp-cookies-accepted')) {
          window.bwpGrantAnalyticsConsent();
          window.bwpLoadGA();
        }
      } catch {
        /* localStorage unavailable (private browsing, SSR, etc.) — skip GA load */
      }
    </script>

    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={Astro.url.href} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="BuildWorkPro" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Organization Schema -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'BuildWorkPro',
        url: config.siteUrl,
        logo: `${config.siteUrl}/logo.png`,
        contactPoint: {
          '@type': 'ContactPoint',
          email: config.email.support,
          contactType: 'customer support',
        },
        sameAs: [],
      })}
    />

    <!-- BreadcrumbList Schema (skipped on the homepage). -->
    {
      showBreadcrumbs && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'BreadcrumbList',
            itemListElement: breadcrumbItems.map((item, i) => ({
              '@type': 'ListItem',
              position: i + 1,
              name: item.name,
              item: item.url,
            })),
          })}
        />
      )
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer
    ></script>
    <title>{title}</title>
  </head>
  <body class="bg-white text-slate-900 font-sans" data-turnstile-sitekey={config.turnstileSiteKey}>
    <slot />
    <CookieConsent />
  </body>
</html>
